# WhatsApp Business Platform — required environment variables
# See: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
#
# WHATSAPP_WABA_ID: Kgolaentle Holdings WABA asset ID (static — does not change)
# WHATSAPP_ACCESS_TOKEN: Permanent System User token from Meta App → System Users
# WHATSAPP_PHONE_NUMBER_ID: Phone Number ID from WhatsApp → API Setup (not the phone number itself)
# WHATSAPP_VERIFY_TOKEN: A secret string you choose — must match what you enter in Meta's webhook config panel

WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_from_meta_app
WHATSAPP_WABA_ID=104200042667877
WHATSAPP_VERIFY_TOKEN=plugapro_webhook_verify_2024

# Pay@ (PAT) merchant payment gateway — required for provider wallet top-ups
# Issued via the Pay@ merchant portal. PAYAT_CLIENT_SECRET is a production secret — never commit it.
# PAYAT_CLIENT_ID / PAYAT_CLIENT_SECRET: OAuth client_credentials issued by Pay@
# PAYAT_SCOPES: OAuth scopes required by the legacy provider wallet RTP flow
# PAYAT_MERCHANT_IDENTIFIER: the integrator identifier assigned in the Pay@ portal (e.g. plug-a-pro)
# PAYAT_WEBHOOK_SECRET: 64-char hex secret configured in Pay@ webhook settings
# PAYAT_MERCHANT_FEE_FIXED_CENTS: optional fixed counter fee in cents added on top of credit amount
# PAYAT_DIAG_KEY: secret key protecting the /api/debug/payat-ping diagnostic endpoint (leave unset to disable)
PAYAT_TOKEN_URL=https://go.payat.co.za/yapi/oauth/token
PAYAT_API_BASE=https://go.payat.co.za/yapi/v1
PAYAT_CLIENT_ID=your-payat-client-id
PAYAT_CLIENT_SECRET=your-payat-client-secret
PAYAT_SCOPES=rtp:create:single
PAYAT_MERCHANT_IDENTIFIER=your-payat-merchant-identifier
PAYAT_WEBHOOK_SECRET=your-64-char-hex-webhook-secret
PAYAT_MERCHANT_FEE_FIXED_CENTS=0
PAYAT_DIAG_KEY=

# Pay@Go RTP (booking/job payment requests)
# Uses OAuth2 client_credentials and merchant RTP endpoints from the Pay@Go OpenAPI.
PAYAT_GO_BASE_URL=https://go.payat.co.za/yapi/v1
PAYAT_GO_MERCHANT_IDENTIFIER=your-payat-go-merchant-identifier
PAYAT_GO_CLIENT_ID=your-payat-go-client-id
PAYAT_GO_CLIENT_SECRET=your-payat-go-client-secret
PAYAT_GO_GRANT_TYPE=client_credentials
PAYAT_GO_SCOPES=rtp:create:single rtp:cancel:single rtp:read
# Optional shared secret for callback route auth (/api/payat-go/callback)
PAYAT_GO_WEBHOOK_SECRET=your-payat-go-webhook-secret
PAYAT_GO_CALLBACK_SECRET=
PAYAT_GO_ENABLED=false
PAYAT_GO_MOCK_MODE=true
PAYAT_GO_CREATE_LIMIT_PER_BOOKING_USER_HOUR=12
PAYAT_GO_STATUS_LIMIT_PER_BOOKING_USER_HOUR=120
PAYAT_GO_CANCEL_LIMIT_PER_BOOKING_USER_HOUR=20
PAYAT_GO_CALLBACK_LIMIT_PER_REFERENCE_HOUR=120

# Provider identity verification — keep real values in managed environment storage only.
IDENTITY_HASH_PEPPER=
IDENTITY_ENC_KEY=
IDENTITY_VERIFICATION_TOKEN_TTL_HOURS=72

# Provider identity verification vendors
OMNICHECK_API_BASE_URL=
OMNICHECK_API_KEY=
OMNICHECK_WEBHOOK_SECRET=
DATANAMIX_API_BASE_URL=
DATANAMIX_API_KEY=
DATANAMIX_WEBHOOK_SECRET=
SMILE_ID_API_BASE_URL=
SMILE_ID_PARTNER_ID=
SMILE_ID_API_KEY=
SMILE_ID_WEBHOOK_SECRET=
THISISME_API_BASE_URL=
THISISME_API_KEY=
THISISME_WEBHOOK_SECRET=
