// Plug A Pro — Marketplace Schema
// Domain model: homeowners post job requests → platform matches to independent providers
// → providers accept leads → quote → book → execute → pay → review

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Customers ────────────────────────────────────────────────────────────────

model Customer {
  id         String   @id @default(cuid())
  // userId is nullable — WhatsApp-only customers start without a Supabase account.
  // When the customer authenticates on the PWA (phone OTP), linkCustomerAccount()
  // fills this in. Both channels resolve to the same record.
  userId     String?  @unique
  phone      String   @unique
  email      String?
  name       String
  notes      String?
  active     Boolean  @default(true)
  isTestUser Boolean  @default(false)
  cohortName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // WhatsApp preferences
  whatsappServiceOptIn      Boolean   @default(true) // lifecycle/utility msgs
  whatsappMarketingOptIn    Boolean   @default(false) // promotional/marketing msgs
  whatsappMarketingOptInAt  DateTime?
  whatsappMarketingOptOutAt DateTime?
  whatsappMarketingSource   String? // "bot" | "pwa" | "admin" | "import"
  lastWhatsappPrefSyncAt    DateTime?

  // Generic opt-in flags (legacy columns, present in production; kept in sync with
  // the whatsappMarketingOptIn / whatsappServiceOptIn fields via merge logic)
  marketingOptIn Boolean @default(false)
  serviceOptIn   Boolean @default(true)

  // Moderation / lifecycle
  isBlocked            Boolean   @default(false)
  blockedReason        String?
  blockedAt            DateTime?
  suspendedUntil       DateTime?
  suspendedReason      String?
  archivedAt           DateTime?
  archiveReason        String?
  purgeAfter           DateTime?
  mergedIntoCustomerId String?
  channel              String? // "PWA" | "WHATSAPP" | "BOTH"
  address              String? // free-text address for quick-edit / display

  isBusinessAccount Boolean @default(false)
  businessName      String?

  // First-touch acquisition attribution (Marketing Acquisition Readiness — Slice B).
  // Stamped once on the first JobRequest that arrives with attribution; never
  // overwritten, even if the same customer later books via a different campaign
  // (that becomes last-touch on the new JobRequest, not a rewrite here).
  firstTouchSource      String?
  firstTouchMedium      String?
  firstTouchCampaign    String?
  firstTouchGclid       String?
  firstTouchFbclid      String?
  firstTouchAt          DateTime?
  firstTouchLandingPath String?
  firstTouchReferrer    String?

  addresses              Address[]
  customerAddresses      CustomerAddress[]
  members                CustomerMember[]        @relation("PrincipalCustomerMembers")
  jobRequests            JobRequest[]
  ratings                Review[]
  messages               MessageEvent[]
  whatsappPreferenceLogs WhatsappPreferenceLog[]
  customerNotes          CustomerNote[]
  mergeEventsAsSource    CustomerMergeEvent[]    @relation("CustomerMergeSource")
  mergeEventsAsTarget    CustomerMergeEvent[]    @relation("CustomerMergeTarget")

  @@map("customers")
}

model Address {
  id             String   @id @default(cuid())
  customerId     String
  label          String? // "Home", "Office"
  street         String
  addressLine1   String?
  addressLine2   String?
  complexName    String?
  unitNumber     String?
  suburb         String
  region         String?
  city           String
  province       String
  postalCode     String?
  // Sensitive structured access details (gate codes, building access info, dog
  // warnings, etc). MUST NOT be returned in any provider safe-preview payload.
  // Visible only after the selected provider has completed final acceptance
  // and the LeadUnlock for that lead exists.
  accessNotes    String?
  locationNodeId String?
  lat            Float?
  lng            Float?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobRequests  JobRequest[]
  locationNode LocationNode? @relation(fields: [locationNodeId], references: [id])

  @@index([locationNodeId])
  @@map("addresses")
}

model CustomerAddress {
  id             String   @id @default(cuid())
  customerId     String
  label          String?
  street         String
  suburb         String
  city           String
  province       String
  postalCode     String?
  lat            Float?
  lng            Float?
  locationNodeId String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  locationNode LocationNode? @relation(fields: [locationNodeId], references: [id])

  @@map("customer_addresses")
}

model CustomerMember {
  id                  String   @id @default(cuid())
  principalCustomerId String
  memberUserId        String
  memberName          String
  memberPhone         String
  role                String   @default("BOOKER")
  active              Boolean  @default(true)
  addedAt             DateTime @default(now())

  principal Customer @relation("PrincipalCustomerMembers", fields: [principalCustomerId], references: [id], onDelete: Cascade)

  @@map("customer_members")
}

// ─── Service area waitlist ────────────────────────────────────────────────────
// Captures contact details for customers/providers outside active service areas.
// Notified automatically when the platform expands to their city.

model ServiceAreaWaitlist {
  id        String   @id @default(cuid())
  phone     String
  name      String?
  category  String?
  suburb    String?
  city      String
  province  String?
  source    String // 'whatsapp' | 'pwa'
  createdAt DateTime @default(now())

  @@unique([phone, city])
  @@index([city])
  @@map("service_area_waitlist")
}

// ─── Location hierarchy ───────────────────────────────────────────────────────
// Four-level tree: PROVINCE → CITY → REGION → SUBURB
// Seeded from lib/service-areas/south-africa.ts. Admin-manageable at runtime.
// For customer capture, SUBURB nodes act as the canonical structured address anchor.
// postalCode is populated only on SUBURB nodes that are valid for new structured capture.

model LocationNode {
  id          String           @id @default(cuid())
  nodeType    LocationNodeType
  // slug is the canonical key — e.g. "gauteng", "gauteng__johannesburg", "gauteng__johannesburg__jhb_north", "gauteng__johannesburg__jhb_north__sandton"
  slug        String           @unique
  label       String
  parentId    String?
  lat         Float?
  lng         Float?
  radiusKm    Float?
  postalCode  String?
  // Denormalised for fast matching without tree-walk joins
  provinceKey String? // set on CITY, REGION, SUBURB nodes
  cityKey     String? // set on REGION and SUBURB nodes
  regionKey   String? // set on SUBURB nodes only
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  parent   LocationNode?  @relation("LocationNodeChildren", fields: [parentId], references: [id])
  children LocationNode[] @relation("LocationNodeChildren")

  technicianServiceAreas TechnicianServiceArea[]
  addresses              Address[]
  customerAddresses      CustomerAddress[]
  candidatePool          CandidatePool[]

  @@index([nodeType, active])
  @@index([provinceKey, nodeType])
  @@index([cityKey, nodeType])
  @@index([regionKey, nodeType])
  @@map("location_nodes")
}

// ─── Providers (independent workers) ─────────────────────────────────────────

model Provider {
  id                        String    @id @default(cuid())
  userId                    String?   @unique // Supabase auth user ID
  phone                     String    @unique
  email                     String?
  name                      String
  bio                       String?
  experience                String?
  skills                    String[]  @default([]) // category slugs: "plumbing", "painting", etc.
  serviceAreas              String[]  @default([]) // suburb/city names they cover
  equipmentTags             String[]  @default([])
  vehicleTypes              String[]  @default([])
  evidenceNote              String?
  portfolioUrls             String[]  @default([])
  active                    Boolean   @default(true)
  isTestUser                Boolean   @default(false)
  cohortName                String?
  availableNow              Boolean   @default(true) // currently online and accepting leads
  verified                  Boolean   @default(false) // internal lead-eligibility flag after marketplace review; not a public guarantee
  averageRating             Float     @default(0)
  reliabilityScore          Float     @default(0.5)
  completedJobsCount        Int       @default(0)
  onTimeRate                Float     @default(1)
  acceptanceRate            Float     @default(1)
  complaintCount            Int       @default(0)
  complaintRate             Float     @default(0)
  providerCancellationCount Int       @default(0)
  cancellationRate          Float     @default(0)
  lateArrivalCount          Int       @default(0)
  punctualityScore          Float     @default(1)
  maxTravelMinutes          Int       @default(90)
  lastKnownLat              Float?
  lastKnownLng              Float?
  lastKnownLocationLabel    String?
  lastKnownLocationAt       DateTime?
  avatarUrl                 String?
  whatsappMarketingOptIn    Boolean   @default(true)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  // Name split — optional; `name` remains the primary display field for backwards compat
  firstName String?
  lastName  String?

  // Provider type — sole-trader vs company; optional until compliance requirement firms up
  providerType String?

  // Lifecycle timestamps
  approvedAt       DateTime? // set when ProviderApplication is approved; used for SLA reporting
  payoutVerifiedAt DateTime? // set when payout banking details are verified

  // Moderation / lifecycle
  status            ProviderStatus @default(ACTIVE)
  kycStatus         KycStatus      @default(NOT_STARTED)
  // KYC hardening — per-provider grace + override audit. All nullable for safe
  // additive rollout; meaning is enforced by lib/provider-lead-eligibility.ts
  // (checkCanBeApproved). `kycGraceUntil` lets a provider be approved/activated
  // without VERIFIED until that timestamp; `kycOverridden*` records a TRUST+
  // override that bypasses the gate with a written reason.
  kycRequiredFrom   DateTime?
  kycGraceUntil     DateTime?
  kycOverriddenBy   String?
  kycOverriddenAt   DateTime?
  kycOverrideReason String?
  suspendedUntil    DateTime?
  suspendedReason   String?
  strikes           Int            @default(0)
  archivedAt        DateTime?
  archiveReason     String?

  schedule                             ProviderSchedule[]
  technicianSkills                     TechnicianSkill[]
  technicianCertifications             TechnicianCertification[]
  technicianServiceAreas               TechnicianServiceArea[]
  technicianAvailability               TechnicianAvailability?
  scheduleItems                        TechnicianScheduleItem[]
  leads                                Lead[]
  leadUnlocks                          LeadUnlock[]
  matches                              Match[]
  jobs                                 Job[]
  reviews                              Review[]
  leadUnlockDisputes                   LeadUnlockDispute[]
  pushSubscriptions                    PushSubscription[]
  applications                         ProviderApplication[]
  preferredByRequests                  JobRequest[]                                 @relation("PreferredProvider")
  selectedForRequests                  JobRequest[]                                 @relation("SelectedProvider")
  assignmentHolds                      AssignmentHold[]
  matchAttempts                        MatchAttempt[]
  selectedDispatchDecisions            DispatchDecision[]                           @relation("DispatchDecisionSelectedProvider")
  providerNotes                        ProviderNote[]
  adminCertifications                  ProviderCertification[]
  equipment                            ProviderEquipment[]
  providerCategories                   ProviderCategory[]
  providerRates                        ProviderRate[]
  leadResponses                        ProviderLeadResponse[]
  leadAccessTokens                     ProviderLeadAccessToken[]
  shortlistItems                       ProviderShortlistItem[]
  liveStatus                           ProviderLiveStatus?
  candidatePool                        CandidatePool[]
  capacity                             ProviderCapacity?
  providerAutoApproveSideEffectMarkers ProviderAutoApproveSideEffectMarker[]
  wallet                               ProviderWallet?
  walletLedgerEntries                  WalletLedgerEntry[]
  paymentIntents                       PaymentIntent[]
  promoAwards                          ProviderPromoAward[]
  redeemedVouchers                     PromoVoucher[]
  campaignRedemptions                  ProviderCampaignRedemption[]
  voucherRedemptionAttempts            VoucherRedemptionAttempt[]
  identityVerifications                ProviderIdentityVerification[]
  identityVerificationPilotAllowlist   ProviderIdentityVerificationPilotAllowlist[]
  profileScores                        ProviderProfileScore[]

  @@index([active, verified])
  @@index([isTestUser])
  @@index([status, createdAt])
  @@index([kycStatus, status])
  @@index([kycGraceUntil])
  @@index([completedJobsCount])
  @@map("providers")
}

model ProviderSchedule {
  id         String  @id @default(cuid())
  providerId String
  dayOfWeek  Int // 0=Sun, 1=Mon, ..., 6=Sat
  startTime  String // "08:00"
  endTime    String // "17:00"
  active     Boolean @default(true)

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, dayOfWeek])
  @@map("provider_schedule")
}

model PushSubscription {
  id         String   @id @default(cuid())
  providerId String
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ─── Provider applications ────────────────────────────────────────────────────

model ProviderApplication {
  id                            String            @id @default(cuid())
  providerId                    String? // set after account is created on approval
  phone                         String
  email                         String? // optional, captured during WhatsApp onboarding for admin review continuity
  name                          String
  skills                        String[]          @default([])
  serviceAreas                  String[]          @default([])
  experience                    String? // e.g. "3–5 years" — set on application submit
  availability                  String? // e.g. "Any day" or "Mon–Sat" — set on application submit
  callOutFee                    Decimal?          @db.Decimal(10, 2)
  hourlyRate                    Decimal?          @db.Decimal(10, 2)
  rateNegotiable                Boolean           @default(true)
  quoteAfterInspection          Boolean           @default(false)
  emergencyAvailable            Boolean           @default(false)
  sameDayJobs                   Boolean           @default(true)
  weekendJobs                   Boolean           @default(false)
  evidenceNote                  String?
  evidenceFileUrls              String[]          @default([])
  idNumber                      String? // POPIA §26 special personal info — do NOT log, export raw, or include in API responses. Encrypt at rest before GA.
  // TODO(POPIA): idNumber stored plaintext — encrypt before GA (§26 special personal info)
  alternateMobileE164           String?           @db.VarChar(32)
  preferredLanguage             String? // Optional preferred language for customer communication
  reference1Name                String?
  reference1Mobile              String?
  reference2Name                String?
  reference2Mobile              String?
  isTestUser                    Boolean           @default(false)
  cohortName                    String?
  status                        ApplicationStatus @default(PENDING)
  notes                         String? // admin review notes
  reviewedAt                    DateTime?
  reviewedById                  String?
  approvalWhatsappSendStartedAt DateTime?
  approvalWhatsappSentAt        DateTime?
  approvalWhatsappExternalId    String?
  submittedAt                   DateTime          @default(now())
  cancelledAt                   DateTime?
  updatedAt                     DateTime          @updatedAt

  provider                           Provider?                                    @relation(fields: [providerId], references: [id])
  attachments                        Attachment[]
  identityVerifications              ProviderIdentityVerification[]
  identityVerificationPilotAllowlist ProviderIdentityVerificationPilotAllowlist[]
  registrationDraft                  ProviderApplicationDraft?
  registrationResumeTokens           RegistrationResumeToken[]

  @@index([approvalWhatsappSentAt])
  @@index([isTestUser, status])
  @@index([status, submittedAt])
  @@map("provider_applications")
}

model ProviderApplicationDraft {
  id                     String    @id @default(cuid())
  phone                  String
  email                  String?
  name                   String?
  businessName           String?
  preferredContact       String?
  identityBasis          String?
  profilePhotoUrl        String?
  skills                 String[]  @default([])
  categorySlugs          String[]  @default([])
  serviceAreas           String[]  @default([])
  locationNodeIds        String[]  @default([])
  experience             String?
  bio                    String?
  availability           String?
  availabilityDays       String[]  @default([])
  availabilityHours      String?
  emergencyAvailable     Boolean   @default(false)
  callOutFee             Decimal?  @db.Decimal(10, 2)
  travelRadiusKm         Int?
  evidenceFileUrls       String[]  @default([])
  evidenceNote           String?
  reference1Name         String?
  reference1Mobile       String?
  reference2Name         String?
  reference2Mobile       String?
  consentAt              DateTime?
  lastCompletedStep      Int       @default(0)
  submittedApplicationId String?   @unique
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  submittedApplication     ProviderApplication?      @relation(fields: [submittedApplicationId], references: [id], onDelete: SetNull)
  registrationResumeTokens RegistrationResumeToken[]

  @@index([phone])
  @@index([submittedApplicationId])
  @@map("provider_application_drafts")
}

model RegistrationResumeToken {
  id            String    @id @default(cuid())
  draftId       String
  applicationId String?
  tokenHash     String    @unique
  purpose       String
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())

  draft       ProviderApplicationDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  application ProviderApplication?     @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([tokenHash])
  @@index([draftId])
  @@index([applicationId])
  @@map("registration_resume_tokens")
}

// ─── Job Requests ─────────────────────────────────────────────────────────────
// A customer's initial request. Platform validates and opens it for matching.

model JobRequest {
  id                              String           @id @default(cuid())
  customerId                      String
  addressId                       String?
  category                        String // "plumbing" | "painting" | "garden" | etc.
  requestRef                      String?          @unique
  source                          String?
  subcategory                     String?
  title                           String // short description: "Leaking tap in bathroom"
  description                     String // full details provided by customer
  urgency                         String?
  budgetPreference                String?
  maxCallOutFee                   Decimal?         @db.Decimal(10, 2)
  providerPreference              String?
  verifiedOnly                    Boolean          @default(false)
  riskLevel                       String?
  certifiedProviderRequired       Boolean          @default(false)
  submittedAt                     DateTime?
  requestedWindowStart            DateTime?
  requestedWindowEnd              DateTime?
  requestedArrivalLatest          DateTime?
  estimatedDurationMinutes        Int?
  requiredSkillTags               String[]         @default([])
  requiredCertificationCodes      String[]         @default([])
  requiredEquipmentTags           String[]         @default([])
  requiredVehicleTypes            String[]         @default([])
  preferredProviderId             String?
  selectedProviderId              String?
  selectedLeadInviteId            String?          @unique
  assignmentMode                  AssignmentMode   @default(AUTO_ASSIGN)
  customerAcceptedAmount          Decimal?         @db.Decimal(10, 2)
  customerAcceptedScope           String?
  autoCreateBookingOnAssignment   Boolean          @default(false)
  customerAccessToken             String?          @unique
  customerAccessTokenExpiresAt    DateTime?
  customerAccessTokenRevokedAt    DateTime?
  latestDispatchDecisionId        String?
  customerAddressId               String?
  isTestRequest                   Boolean          @default(false)
  cohortName                      String?
  // Paid campaign attribution — first-touch UTM captured on landing, persisted at submission
  utmSource                       String?
  utmMedium                       String?
  utmCampaign                     String?
  utmContent                      String?
  // Extended attribution (Marketing Acquisition Readiness — Slice B). The same
  // capture also stores the rich first/last-touch snapshot in `attribution`.
  utmTerm                         String?
  gclid                           String?
  gbraid                          String?
  wbraid                          String?
  fbclid                          String?
  msclkid                         String?
  referrer                        String?
  landingPath                     String?
  firstTouchAt                    DateTime?
  lastTouchAt                     DateTime?
  attribution                     Json?
  status                          JobRequestStatus @default(PENDING_VALIDATION)
  expiresAt                       DateTime? // if no match within window, mark EXPIRED
  customerNoMatchNotifiedAt       DateTime?
  customerRematchCheckSentAt      DateTime?
  customerRematchCheckRespondedAt DateTime?
  customerRematchCheckOutcome     String?
  // Alternative-slot negotiation — set when orchestrator sends slot options after a NO_MATCH
  altSlotNegotiationSentAt        DateTime?
  altSlotNegotiationOutcome       String? // 'CUSTOMER_SELECTED' | 'CUSTOMER_DECLINED' | 'PROVIDER_DECLINED' | 'EXPIRED'
  matchFoundWhatsappSentAt        DateTime? // idempotency guard — set when WA match-found notification is sent
  enRouteWhatsappSentAt           DateTime? // idempotency guard — set when WA en-route notification is sent
  createdAt                       DateTime         @default(now())
  updatedAt                       DateTime         @updatedAt

  customer                 Customer                  @relation(fields: [customerId], references: [id])
  address                  Address?                  @relation(fields: [addressId], references: [id])
  preferredProvider        Provider?                 @relation("PreferredProvider", fields: [preferredProviderId], references: [id])
  selectedProvider         Provider?                 @relation("SelectedProvider", fields: [selectedProviderId], references: [id])
  selectedLeadInvite       Lead?                     @relation("SelectedLeadInvite", fields: [selectedLeadInviteId], references: [id])
  attachments              Attachment[]
  leads                    Lead[]
  shortlists               ProviderShortlist[]
  match                    Match?
  scheduleItems            TechnicianScheduleItem[]
  matchAttempts            MatchAttempt[]
  assignmentHolds          AssignmentHold[]
  dispatchDecisions        DispatchDecision[]
  providerLeadAccessTokens ProviderLeadAccessToken[]
  frictionSignals          RequestFrictionSignal[]

  @@index([status, createdAt])
  @@index([isTestRequest, status])
  @@map("job_requests")
}

// ─── Leads ────────────────────────────────────────────────────────────────────
// Platform broadcasts a job request to matched providers.
// First provider to accept the lead gets the match.

model Lead {
  id                      String     @id @default(cuid())
  jobRequestId            String
  providerId              String
  dispatchDecisionId      String?
  matchAttemptId          String?
  assignmentHoldId        String?
  safePreviewToken        String?    @unique
  matchScore              Float?
  rankingPosition         Int?
  status                  LeadStatus @default(SENT)
  sentAt                  DateTime   @default(now())
  viewedAt                DateTime?
  respondedAt             DateTime?
  customerSelectedAt      DateTime?
  providerAcceptedAt      DateTime?
  declinedAt              DateTime?
  expiredAt               DateTime?
  cancelledAt             DateTime?
  expiresAt               DateTime? // provider must respond within this window
  reminderSentAt          DateTime? // set once when the 1-hour reminder WhatsApp is sent
  notifiedAt              DateTime? // set when the provider is first notified of customer selection
  notificationAttemptedAt DateTime? // idempotency lock while sending provider selection notifications
  isTestLead              Boolean    @default(false)
  cohortName              String?

  jobRequest            JobRequest                @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  provider              Provider                  @relation(fields: [providerId], references: [id])
  dispatchDecision      DispatchDecision?         @relation(fields: [dispatchDecisionId], references: [id], onDelete: SetNull)
  matchAttempt          MatchAttempt?             @relation(fields: [matchAttemptId], references: [id], onDelete: SetNull)
  assignmentHold        AssignmentHold?           @relation(fields: [assignmentHoldId], references: [id], onDelete: SetNull)
  unlock                LeadUnlock?
  providerResponses     ProviderLeadResponse[]
  accessTokens          ProviderLeadAccessToken[]
  shortlistItems        ProviderShortlistItem[]
  selectedForJobRequest JobRequest?               @relation("SelectedLeadInvite")
  selectedForJob        Job?                      @relation("JobSelectedLeadInvite")

  @@unique([jobRequestId, providerId])
  @@index([jobRequestId, status])
  @@index([providerId, status])
  @@index([isTestLead, status])
  @@map("leads")
}

model LeadUnlock {
  id                  String                   @id @default(cuid())
  // One unlock per dispatched Lead. This relies on the current 1:1 Lead
  // dispatch model; revisit before introducing pooled multi-provider dispatch.
  leadId              String                   @unique
  providerId          String
  matchId             String?
  creditsCharged      Int
  creditTypeBreakdown Json                     @default("{}")
  status              LeadUnlockStatus         @default(UNLOCKED)
  isTestUnlock        Boolean                  @default(false)
  cohortName          String?
  unlockedAt          DateTime                 @default(now())
  disputeReason       LeadUnlockDisputeReason?
  disputeNotes        String?
  disputedAt          DateTime?
  resolvedAt          DateTime?
  resolvedBy          String?
  refundedAt          DateTime?
  refundReason        String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  lead     Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  provider Provider           @relation(fields: [providerId], references: [id], onDelete: Cascade)
  match    Match?             @relation(fields: [matchId], references: [id], onDelete: SetNull)
  dispute  LeadUnlockDispute?

  @@index([providerId, unlockedAt])
  @@index([matchId])
  @@index([isTestUnlock])
  @@map("lead_unlocks")
}

model LeadUnlockDispute {
  id           String                  @id @default(cuid())
  leadUnlockId String                  @unique
  providerId   String
  reason       LeadUnlockDisputeReason
  notes        String?
  status       LeadUnlockDisputeStatus @default(OPEN)
  createdAt    DateTime                @default(now())
  resolvedAt   DateTime?
  resolvedBy   String?
  adminNotes   String?

  leadUnlock LeadUnlock @relation(fields: [leadUnlockId], references: [id], onDelete: Cascade)
  provider   Provider   @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, createdAt])
  @@index([status, createdAt])
  @@map("lead_unlock_disputes")
}

// ─── Match ────────────────────────────────────────────────────────────────────
// Once a provider accepts a lead, a Match is created linking customer to provider.

model Match {
  id                  String      @id @default(cuid())
  jobRequestId        String      @unique
  providerId          String
  status              MatchStatus @default(MATCHED)
  inspectionNeeded    Boolean     @default(false)
  customerContactedAt DateTime?
  plannedArrivalStart DateTime?
  plannedArrivalEnd   DateTime?
  plannedArrivalNote  String?
  providerOnTheWayAt  DateTime?
  providerArrivedAt   DateTime?
  providerStartedAt   DateTime?
  providerCompletedAt DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  jobRequest      JobRequest       @relation(fields: [jobRequestId], references: [id])
  provider        Provider         @relation(fields: [providerId], references: [id])
  inspectionSlots InspectionSlot[]
  quotes          Quote[]
  booking         Booking?
  leadUnlocks     LeadUnlock[]
  reviews         Review[]

  completionCheckSentAt  DateTime?
  completionCheckStatus  CompletionCheckStatus?
  completionCheckRetries Int                    @default(0)
  reviewRequestSentAt    DateTime?

  @@index([jobRequestId])
  @@index([providerId, status])
  @@index([status, createdAt])
  @@map("matches")
}

// ─── Inspection ───────────────────────────────────────────────────────────────
// Optional pre-quote site visit to assess scope before quoting.

model InspectionSlot {
  id          String           @id @default(cuid())
  matchId     String
  proposedAt  DateTime // provider proposes a time
  confirmedAt DateTime? // customer confirms
  completedAt DateTime?
  status      InspectionStatus @default(PROPOSED)
  notes       String?

  match       Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@map("inspection_slots")
}

// ─── Quotes ───────────────────────────────────────────────────────────────────
// Provider's formal quote for the job. Customer approves before booking is created.

model Quote {
  id                     String      @id @default(cuid())
  matchId                String
  amount                 Decimal     @db.Decimal(10, 2)
  labourCost             Decimal     @default(0) @db.Decimal(10, 2)
  materialsCost          Decimal     @default(0) @db.Decimal(10, 2)
  estimatedHours         Float?
  description            String // what is included in the quoted price
  validUntil             DateTime?
  preferredDate          DateTime?
  postInspection         Boolean     @default(false)
  approvalToken          String      @unique
  status                 QuoteStatus @default(PENDING)
  approvedAt             DateTime?
  declinedAt             DateTime?
  approvalWhatsappSentAt DateTime? // idempotency guard — set when WA approval notification is sent
  notes                  String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  match   Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  booking Booking?

  @@index([matchId])
  @@index([status, createdAt])
  @@map("quotes")
}

// ─── Bookings ─────────────────────────────────────────────────────────────────
// Created once a quote is approved. Represents a confirmed, scheduled job.

model Booking {
  id               String        @id @default(cuid())
  matchId          String        @unique
  quoteId          String        @unique
  status           BookingStatus @default(SCHEDULED)
  scheduledDate    DateTime
  scheduledWindow  String? // "09:00-12:00"
  scheduledStartAt DateTime?
  scheduledEndAt   DateTime?
  notes            String?
  cancelReason     String?
  rescheduleCount  Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  match         Match                    @relation(fields: [matchId], references: [id])
  quote         Quote                    @relation(fields: [quoteId], references: [id])
  job           Job?
  payment       Payment?
  invoice       Invoice?
  messages      MessageEvent[]
  scheduleItems TechnicianScheduleItem[]
  statusHistory BookingStatusEvent[]

  @@index([status, createdAt])
  @@index([matchId])
  @@map("bookings")
}

model BookingStatusEvent {
  id         String         @id @default(cuid())
  bookingId  String
  fromStatus BookingStatus?
  toStatus   BookingStatus
  actorId    String
  actorRole  String
  notes      String?
  timestamp  DateTime       @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_status_events")
}

// ─── Jobs (execution) ─────────────────────────────────────────────────────────

model Job {
  id                        String    @id @default(cuid())
  bookingId                 String    @unique
  providerId                String
  jobRef                    String?   @unique
  selectedLeadInviteId      String?   @unique
  status                    JobStatus @default(SCHEDULED)
  isTestJob                 Boolean   @default(false)
  cohortName                String?
  notes                     String?
  completionNote            String?
  assignedAt                DateTime?
  scheduledArrivalAt        DateTime?
  arrivalTimeConfirmedAt    DateTime?
  arrivedAt                 DateTime?
  startedAt                 DateTime?
  completedAt               DateTime?
  failureReason             String?
  providerCurrentLat        Float?
  providerCurrentLng        Float?
  providerLocationSharedAt  DateTime?
  invoiceWhatsappSentAt     DateTime? // idempotency guard — set when invoice WA template is sent to customer
  runningLateWhatsappSentAt DateTime? // idempotency guard — set when running-late WA template is sent to customer
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  booking            Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider           Provider         @relation(fields: [providerId], references: [id])
  selectedLeadInvite Lead?            @relation("JobSelectedLeadInvite", fields: [selectedLeadInviteId], references: [id])
  photos             Attachment[]
  extras             ExtraWork[]
  statusHistory      JobStatusEvent[]
  payout             ProviderPayout?

  @@index([status, createdAt])
  @@index([providerId, status])
  @@index([bookingId])
  @@map("jobs")
}

model ProviderCategory {
  id                    String   @id @default(cuid())
  providerId            String
  categoryId            String?
  categorySlug          String
  subServices           String[] @default([])
  yearsExperience       Float?
  skillLevel            String?
  approvalStatus        String   @default("PENDING_REVIEW")
  certificationRequired Boolean  @default(false)
  certificationStatus   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  provider Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([providerId, categorySlug])
  @@index([categorySlug, approvalStatus])
  @@map("provider_categories")
}

model ProviderRate {
  id                   String   @id @default(cuid())
  providerId           String
  categoryId           String?
  categorySlug         String
  callOutFee           Decimal? @db.Decimal(10, 2)
  hourlyRate           Decimal? @db.Decimal(10, 2)
  dayRate              Decimal? @db.Decimal(10, 2)
  rateNegotiable       Boolean  @default(true)
  quoteAfterInspection Boolean  @default(false)
  emergencySurcharge   Decimal? @db.Decimal(10, 2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  provider Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([providerId, categorySlug])
  @@index([categorySlug])
  @@map("provider_rates")
}

model ProviderLeadResponse {
  id                 String    @id @default(cuid())
  leadInviteId       String
  providerId         String
  response           String
  callOutFee         Decimal?  @db.Decimal(10, 2)
  estimatedArrivalAt DateTime?
  rateType           String?
  rateAmount         Decimal?  @db.Decimal(10, 2)
  negotiable         Boolean   @default(true)
  providerNote       String?
  source             String?
  idempotencyKey     String?   @unique
  createdAt          DateTime  @default(now())

  leadInvite Lead     @relation(fields: [leadInviteId], references: [id], onDelete: Cascade)
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([leadInviteId, createdAt])
  @@index([providerId, createdAt])
  @@map("provider_lead_responses")
}

model ProviderLeadAccessToken {
  id           String    @id @default(cuid())
  jti          String    @unique
  tokenHash    String    @unique
  leadId       String
  providerId   String
  jobRequestId String?
  scopes       String[]  @default([])
  expiresAt    DateTime
  issuedAt     DateTime  @default(now())
  revokedAt    DateTime?
  consumedAt   DateTime?

  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  provider   Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  jobRequest JobRequest? @relation(fields: [jobRequestId], references: [id], onDelete: SetNull)

  @@index([leadId, issuedAt])
  @@index([providerId, issuedAt])
  @@index([jobRequestId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("provider_lead_access_tokens")
}

enum ProviderShortlistStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
  CANCELLED
  PUBLISHED
  SUPERSEDED
}

model ProviderShortlist {
  id          String                  @id @default(cuid())
  requestId   String
  status      ProviderShortlistStatus @default(DRAFT)
  createdAt   DateTime                @default(now())
  publishedAt DateTime?
  updatedAt   DateTime                @updatedAt

  request JobRequest              @relation(fields: [requestId], references: [id], onDelete: Cascade)
  items   ProviderShortlistItem[]

  @@unique([requestId, status])
  @@map("provider_shortlists")
}

model ProviderShortlistItem {
  id                     String    @id @default(cuid())
  shortlistId            String
  leadInviteId           String
  providerId             String
  rank                   Int
  customerPreferenceRank Int?
  matchScore             Float?
  displayCallOutFee      Decimal?  @db.Decimal(10, 2)
  displayArrivalTime     DateTime?
  customerSelectedAt     DateTime?
  createdAt              DateTime  @default(now())

  shortlist  ProviderShortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  leadInvite Lead              @relation(fields: [leadInviteId], references: [id], onDelete: Cascade)
  provider   Provider          @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([shortlistId, leadInviteId])
  @@unique([shortlistId, providerId])
  @@index([providerId])
  @@map("provider_shortlist_items")
}

model JobStatusEvent {
  id         String     @id @default(cuid())
  jobId      String
  fromStatus JobStatus?
  toStatus   JobStatus
  actorId    String // user ID of who triggered the change
  actorRole  String // 'provider' | 'customer' | 'admin' | 'system'
  notes      String?
  timestamp  DateTime   @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_status_events")
}

model ExtraWork {
  id             String         @id @default(cuid())
  jobId          String
  description    String
  amount         Decimal        @db.Decimal(10, 2)
  status         ApprovalStatus @default(PENDING)
  approvalToken  String         @unique @default(cuid())
  approvedAt     DateTime?
  declinedAt     DateTime?
  approvedByName String?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("extra_work")
}

// ─── Attachments ──────────────────────────────────────────────────────────────

model Attachment {
  id                    String   @id @default(cuid())
  jobId                 String?
  inspectionSlotId      String?
  jobRequestId          String?
  providerApplicationId String? // set for evidence files uploaded during WA registration
  url                   String
  blobKey               String // Vercel Blob key for deletion
  mimeType              String
  sizeBytes             Int
  label                 String? // "before", "after", "inspection", "receipt", "evidence"
  caption               String?
  // Qualified Shortlist: when false, the attachment must be excluded from
  // provider safe-preview payloads. Customer-uploaded photos are safe by
  // default; identity-document or sensitive-asset photos can be flagged false
  // by uploaders or admin moderation. Server-side preview renderers should
  // honour this flag in addition to the customer/address visibility gate.
  safeForPreview        Boolean  @default(true)
  uploadedBy            String // user ID or "system:whatsapp" for bot uploads
  createdAt             DateTime @default(now())

  job                 Job?                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  inspectionSlot      InspectionSlot?      @relation(fields: [inspectionSlotId], references: [id], onDelete: Cascade)
  jobRequest          JobRequest?          @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  providerApplication ProviderApplication? @relation(fields: [providerApplicationId], references: [id], onDelete: SetNull)

  @@map("attachments")
}

// ─── Provider identity verification ──────────────────────────────────────────

model ProviderIdentityVerification {
  id                           String                     @id @default(cuid())
  providerId                   String?
  providerApplicationId        String?
  channel                      VerificationChannel
  identityBasis                IdentityBasis
  issuingCountry               String?
  nationality                  String?
  identifierHash               String?
  identifierLast4              String?
  identifierEncrypted          String?
  documentNumberHash           String?
  documentNumberLast4          String?
  documentExpiryDate           DateTime?
  dobDerived                   DateTime?
  genderDerived                String?
  citizenshipDerived           String?
  status                       VerificationStatus         @default(NOT_STARTED)
  decision                     VerificationDecision?
  assuranceLevel               VerificationAssuranceLevel @default(LOW)
  riskFlags                    Json?
  failureReasonCode            String?
  providerNameComparisonResult String?
  selfieMatchScore             Float?
  livenessScore                Float?
  documentConfidenceScore      Float?
  dhaMatchResult               String?
  immigrationStatusResult      String?
  sourceCheckProvider          String?
  vendorReference              String?
  vendorWorkflowId             String?
  costEstimateCents            Int?
  costCurrency                 String?
  decisionAt                   DateTime?
  livenessSessionReference     String?
  livenessSessionUrlEncrypted  String?
  livenessSessionExpiresAt     DateTime?
  consentVendorKey             String?
  consentVendorDisplayName     String?
  consentTextHash              String?
  rawPayloadRedacted           Json?
  consentAcceptedAt            DateTime?
  reviewedById                 String?
  reviewedAt                   DateTime?
  auditLogReference            String?
  expiresAt                    DateTime?
  accessTokenHash              String?                    @unique
  accessTokenExpiresAt         DateTime?
  accessTokenLastUsedAt        DateTime?
  accessTokenRevokedAt         DateTime?
  countsTowardAttemptCap       Boolean                    @default(true)
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt

  provider            Provider?                          @relation(fields: [providerId], references: [id], onDelete: SetNull)
  providerApplication ProviderApplication?               @relation(fields: [providerApplicationId], references: [id], onDelete: SetNull)
  documents           ProviderIdentityDocument[]
  events              ProviderVerificationEvent[]
  webhookEvents       ProviderVerificationWebhookEvent[]
  consentEvents       ProviderIdentityConsentEvent[]
  reviews             ProviderVerificationReview[]
  securityEvents      SecurityEvent[]
  sensitiveAccessLogs ProviderSensitiveDataAccessLog[]

  @@index([identifierHash])
  @@index([documentNumberHash])
  @@index([status, createdAt])
  @@index([providerId])
  @@index([providerId, status, countsTowardAttemptCap])
  @@index([providerApplicationId])
  @@index([assuranceLevel, status])
  @@index([sourceCheckProvider, vendorReference])
  @@index([sourceCheckProvider, vendorWorkflowId])
  @@index([sourceCheckProvider, livenessSessionReference])
  @@map("provider_identity_verifications")
}

model ProviderIdentityDocument {
  id             String                     @id @default(cuid())
  verificationId String
  documentKind   IdentityDocumentKind
  blobKey        String
  mimeType       String
  sizeBytes      Int
  sha256         String
  status         VerificationDocumentStatus @default(UPLOADED)
  deleteAfter    DateTime
  deletedAt      DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  verification        ProviderIdentityVerification     @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  sensitiveAccessLogs ProviderSensitiveDataAccessLog[]

  @@index([verificationId])
  @@index([deleteAfter, deletedAt])
  @@index([sha256])
  @@map("provider_identity_documents")
}

model ProviderVerificationEvent {
  id             String                @id @default(cuid())
  verificationId String
  fromStatus     VerificationStatus?
  toStatus       VerificationStatus
  actorId        String?
  actorRole      String?
  decision       VerificationDecision?
  reasonCode     String?
  metadata       Json?
  createdAt      DateTime              @default(now())

  verification ProviderIdentityVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId, createdAt])
  @@map("provider_verification_events")
}

model ProviderVerificationReview {
  id             String               @id @default(cuid())
  verificationId String
  reviewerId     String
  decision       VerificationDecision
  notes          String?
  createdAt      DateTime             @default(now())

  verification ProviderIdentityVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId, createdAt])
  @@index([reviewerId, createdAt])
  @@map("provider_verification_reviews")
}

model ProviderSensitiveDataAccessLog {
  id             String                      @id @default(cuid())
  verificationId String?
  documentId     String?
  actorId        String
  actorRole      String
  accessType     SensitiveIdentityAccessType
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime                    @default(now())

  verification ProviderIdentityVerification? @relation(fields: [verificationId], references: [id], onDelete: SetNull)
  document     ProviderIdentityDocument?     @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([verificationId, createdAt])
  @@index([documentId, createdAt])
  @@index([actorId, createdAt])
  @@map("provider_sensitive_data_access_logs")
}

model ProviderVerificationWebhookEvent {
  id                       String    @id @default(cuid())
  verificationId           String?
  vendorKey                String
  vendorEventId            String?
  idempotencyKey           String    @unique
  vendorReference          String?
  livenessSessionReference String?
  eventType                String?
  signatureValid           Boolean
  payloadHash              String?
  rawPayloadRedacted       Json?
  receivedAt               DateTime  @default(now())
  processedAt              DateTime?
  processingError          String?

  verification   ProviderIdentityVerification? @relation(fields: [verificationId], references: [id], onDelete: SetNull)
  securityEvents SecurityEvent[]

  @@index([verificationId, receivedAt])
  @@index([vendorKey, vendorReference])
  @@index([vendorKey, livenessSessionReference])
  @@map("provider_verification_webhook_events")
}

model VerificationVendorConfig {
  vendorKey           String   @id
  active              Boolean  @default(false)
  confidenceThreshold Float    @default(0.9)
  livenessRequired    Boolean  @default(true)
  configJson          Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("verification_vendor_configs")
}

model ProviderIdentityVerificationPilotAllowlist {
  id                    String   @id @default(cuid())
  providerId            String?
  providerApplicationId String?
  reason                String?
  createdById           String?
  createdAt             DateTime @default(now())

  provider            Provider?            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerApplication ProviderApplication? @relation(fields: [providerApplicationId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([providerApplicationId])
  @@map("provider_identity_verification_pilot_allowlist")
}

model ProviderIdentityConsentEvent {
  id                      String              @id @default(cuid())
  verificationId          String
  vendorKey               String
  vendorDisplayName       String
  consentTextHash         String
  consentTextVersion      String
  channel                 VerificationChannel
  acceptedAt              DateTime            @default(now())
  acceptedByProviderId    String?
  acceptedByApplicationId String?
  metadata                Json?

  verification ProviderIdentityVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId, acceptedAt])
  @@index([consentTextHash])
  @@map("provider_identity_consent_events")
}

// ─── Payments & Payouts ───────────────────────────────────────────────────────

model Payment {
  id             String                @id @default(cuid())
  bookingId      String                @unique
  status         PaymentStatus         @default(PENDING)
  collectionMode PaymentCollectionMode @default(OFFLINE_RECORDED)
  amount         Decimal               @db.Decimal(10, 2)
  currency       String                @default("ZAR")
  pspProvider    String? // "peach" | "yoco" | "payfast"
  pspReference   String?
  pspCheckoutId  String?
  checkoutUrl    String?
  paidAt         DateTime?
  failureReason  String?
  refundedAmount Decimal?              @db.Decimal(10, 2)
  refundedAt     DateTime?
  metadata       Json                  @default("{}")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([bookingId])
  @@index([pspProvider, pspCheckoutId])
  @@map("payments")
}

model ProviderPayout {
  id             String       @id @default(cuid())
  jobId          String       @unique
  providerId     String
  grossAmount    Decimal      @db.Decimal(10, 2) // customer paid amount
  commissionRate Decimal      @db.Decimal(5, 4) // e.g. 0.1500 = 15%
  commissionAmt  Decimal      @db.Decimal(10, 2)
  netAmount      Decimal      @db.Decimal(10, 2) // gross - commission
  status         PayoutStatus @default(PENDING)
  processedAt    DateTime?
  reference      String? // bank transfer reference
  createdAt      DateTime     @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([providerId, createdAt])
  @@map("provider_payouts")
}

model PaymentIntent {
  id                     String              @id @default(cuid())
  providerId             String
  amountCents            Int
  currency               String              @default("ZAR")
  creditsToIssue         Int
  paymentMethod          PaymentIntentMethod
  paymentReference       String              @unique
  status                 PaymentIntentStatus @default(PENDING_PAYMENT)
  providerCellphone      String?
  gatewayReference       String?
  bankStatementReference String?
  proofOfPaymentUrl      String?
  adminNote              String?
  // Payfast ITN fields — populated when a Payfast notification arrives.
  itnReceivedAt          DateTime?
  itnPaymentStatus       String?
  itnAmountCents         Int?
  creditedLedgerEntryId  String?
  createdAt              DateTime            @default(now())
  paidAt                 DateTime?
  creditedAt             DateTime?
  expiresAt              DateTime?
  metadata               Json                @default("{}")
  // Pay@ merchant RTP fields — populated after a successful rtp/create/single call.
  sourceReference        String? // retail till reference (numeric, shown to provider at counter)
  requestToPayId         Int? // Pay@ internal RTP integer id (for rtp:read / rtp:cancel)

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, createdAt])
  @@index([status, createdAt])
  @@index([bankStatementReference])
  @@index([sourceReference])
  @@map("payment_intents")
}

// ─── Provider credit wallet ──────────────────────────────────────────────────
// Credits are the provider-facing paid-lead currency. Rand values are kept out
// of wallet balances; current product pricing is defined in code as
// 1 Plug-A-Pro Credit = R50. Immutable ledger rows are the accounting source of
// truth. Cached balances exist only to make gating and display fast.

model ProviderWallet {
  id                 String               @id @default(cuid())
  providerId         String               @unique
  paidCreditBalance  Int                  @default(0)
  promoCreditBalance Int                  @default(0)
  // reservedCreditBalance is intentionally omitted in this foundation PR because
  // there is no active multi-step lead reservation flow yet. Add it when unlocks
  // need holds that can expire or be captured later.
  status             ProviderWalletStatus @default(ACTIVE)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  provider      Provider            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  ledgerEntries WalletLedgerEntry[]

  @@map("provider_wallets")
}

model WalletLedgerEntry {
  id                       String                @id @default(cuid())
  walletId                 String
  providerId               String
  entryType                WalletLedgerEntryType
  creditType               WalletCreditType
  amountCredits            Int
  isTestTransaction        Boolean               @default(false)
  cohortName               String?
  balanceAfterPaidCredits  Int
  balanceAfterPromoCredits Int
  referenceType            String
  referenceId              String
  description              String?
  // idempotencyKey prevents duplicate credit writes under retries or double-delivery
  idempotencyKey           String?               @unique
  // traceId propagated from the originating payment or admin action for distributed tracing
  traceId                  String?
  // source identifies the system component that wrote the entry: "system" | "admin" | "payment_intent" | "promo"
  source                   String?
  metadata                 Json                  @default("{}")
  createdAt                DateTime              @default(now())
  createdBy                String?

  wallet   ProviderWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  provider Provider       @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([providerId, createdAt])
  @@index([referenceType, referenceId])
  @@index([isTestTransaction, createdAt])
  @@map("wallet_ledger_entries")
}

model ProviderPromoAward {
  id             String                   @id @default(cuid())
  providerId     String
  awardType      ProviderPromoAwardType
  creditsAwarded Int
  status         ProviderPromoAwardStatus @default(AWARDED)
  referenceType  String
  referenceId    String
  awardedAt      DateTime                 @default(now())
  revokedAt      DateTime?
  metadata       Json                     @default("{}")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, awardType])
  @@index([providerId, awardedAt])
  @@index([referenceType, referenceId])
  @@map("provider_promo_awards")
}

model VoucherBatch {
  id           String    @id @default(cuid())
  // Human-readable name for this print run, e.g. "Pilot Provider Flyer — May 2026"
  name         String
  // Short identifier used in duplicate-redemption checks, e.g. "PILOT_PROVIDER_FLYER"
  campaignCode String    @unique
  creditAmount Int       @default(1)
  count        Int
  expiresAt    DateTime?
  createdById  String
  createdBy    AdminUser @relation(fields: [createdById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vouchers PromoVoucher[]

  @@map("voucher_batches")
}

model PromoVoucher {
  id                   String        @id @default(cuid())
  // SHA-256 hash of the normalised (no dashes, uppercase) code.
  // The raw code is NEVER stored here — only exposed once at CSV export time.
  codeHash             String        @unique
  status               VoucherStatus @default(ACTIVE)
  creditAmount         Int           @default(1)
  // Maximum times this code can be redeemed. Always 1 for the pilot.
  maxRedemptions       Int           @default(1)
  redemptionCount      Int           @default(0)
  batchId              String
  batch                VoucherBatch  @relation(fields: [batchId], references: [id])
