// Plug-A-Pro — Marketplace Schema
// Domain model: homeowners post job requests → platform matches to independent providers
// → providers accept leads → quote → book → execute → pay → review

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Customers ────────────────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  // userId is nullable — WhatsApp-only customers start without a Supabase account.
  // When the customer authenticates on the PWA (phone OTP), linkCustomerAccount()
  // fills this in. Both channels resolve to the same record.
  userId    String?  @unique
  phone     String   @unique
  email     String?
  name      String
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // WhatsApp preferences
  whatsappServiceOptIn      Boolean   @default(true)   // lifecycle/utility msgs
  whatsappMarketingOptIn    Boolean   @default(false)  // promotional/marketing msgs
  whatsappMarketingOptInAt  DateTime?
  whatsappMarketingOptOutAt DateTime?
  whatsappMarketingSource   String?   // "bot" | "pwa" | "admin" | "import"
  lastWhatsappPrefSyncAt    DateTime?

  // Admin CRUD fields — WS-B.1
  address         String?                // free-text address for legacy/quick reference
  isBlocked       Boolean                @default(false)
  blockedReason   String?
  blockedAt       DateTime?
  suspendedUntil  DateTime?
  suspendedReason String?
  internalFlags   CustomerInternalFlag[] @default([])
  marketingOptIn  Boolean                @default(false)
  serviceOptIn    Boolean                @default(true)
  archivedAt      DateTime?
  archiveReason   String?
  channel         CustomerChannel?
  purgeAfter      DateTime?
  mergedIntoCustomerId String?

  addresses              Address[]
  jobRequests            JobRequest[]
  ratings                Review[]
  messages               MessageEvent[]
  whatsappPreferenceLogs WhatsappPreferenceLog[]
  customerNotes          CustomerNote[]
  mergedIntoCustomer     Customer?           @relation("CustomerMergeTarget", fields: [mergedIntoCustomerId], references: [id])
  mergedCustomers        Customer[]          @relation("CustomerMergeTarget")
  sourceMergeEvents      CustomerMergeEvent[] @relation("CustomerMergeSource")
  targetMergeEvents      CustomerMergeEvent[] @relation("CustomerMergeTarget")

  @@map("customers")
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  label      String?  // "Home", "Office"
  street     String
  addressLine1 String?
  addressLine2 String?
  complexName String?
  unitNumber  String?
  suburb     String
  region     String?
  city       String
  province   String
  postalCode     String?
  locationNodeId String?
  lat            Float?
  lng            Float?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobRequests JobRequest[]
  locationNode LocationNode? @relation(fields: [locationNodeId], references: [id])

  @@index([locationNodeId])
  @@map("addresses")
}

// ─── Service area waitlist ────────────────────────────────────────────────────
// Captures contact details for customers/providers outside active service areas.
// Notified automatically when the platform expands to their city.

model ServiceAreaWaitlist {
  id        String   @id @default(cuid())
  phone     String
  name      String?
  category  String?
  suburb    String?
  city      String
  province  String?
  source    String   // 'whatsapp' | 'pwa'
  createdAt DateTime @default(now())

  @@unique([phone, city])
  @@index([city])
  @@map("service_area_waitlist")
}

// ─── Location hierarchy ───────────────────────────────────────────────────────
// Four-level tree: PROVINCE → CITY → REGION → SUBURB
// Seeded from lib/service-areas/south-africa.ts. Admin-manageable at runtime.
// For customer capture, SUBURB nodes act as the canonical structured address anchor.
// postalCode is populated only on SUBURB nodes that are valid for new structured capture.

model LocationNode {
  id          String           @id @default(cuid())
  nodeType    LocationNodeType
  // slug is the canonical key — e.g. "gauteng", "gauteng__johannesburg", "gauteng__johannesburg__jhb_north", "gauteng__johannesburg__jhb_north__sandton"
  slug        String           @unique
  label       String
  parentId    String?
  lat         Float?
  lng         Float?
  radiusKm    Float?
  postalCode  String?
  // Denormalised for fast matching without tree-walk joins
  provinceKey String?          // set on CITY, REGION, SUBURB nodes
  cityKey     String?          // set on REGION and SUBURB nodes
  regionKey   String?          // set on SUBURB nodes only
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  parent   LocationNode?  @relation("LocationNodeChildren", fields: [parentId], references: [id])
  children LocationNode[] @relation("LocationNodeChildren")

  technicianServiceAreas TechnicianServiceArea[]
  addresses              Address[]

  @@index([nodeType, active])
  @@index([provinceKey, nodeType])
  @@index([cityKey, nodeType])
  @@index([regionKey, nodeType])
  @@map("location_nodes")
}

// ─── Providers (independent workers) ─────────────────────────────────────────

model Provider {
  id           String   @id @default(cuid())
  userId       String?  @unique // Supabase auth user ID
  phone        String   @unique
  email        String?
  name         String
  bio          String?
  experience   String?
  skills       String[] @default([]) // category slugs: "plumbing", "painting", etc.
  serviceAreas String[] @default([]) // suburb/city names they cover
  equipmentTags String[] @default([])
  vehicleTypes String[] @default([])
  evidenceNote String?
  portfolioUrls String[] @default([])
  active       Boolean  @default(true)
  availableNow Boolean  @default(true)   // currently online and accepting leads
  verified     Boolean  @default(false) // internal lead-eligibility flag after marketplace review; not a public guarantee
  averageRating Float   @default(0)
  reliabilityScore Float @default(0.5)
  completedJobsCount Int @default(0)
  onTimeRate   Float    @default(1)
  acceptanceRate Float  @default(1)
  complaintCount Int    @default(0)
  complaintRate Float   @default(0)
  providerCancellationCount Int @default(0)
  cancellationRate Float @default(0)
  lateArrivalCount Int  @default(0)
  punctualityScore Float @default(1)
  maxTravelMinutes Int  @default(90)
  lastKnownLat Float?
  lastKnownLng Float?
  lastKnownLocationLabel String?
  lastKnownLocationAt DateTime?
  avatarUrl    String?
  whatsappMarketingOptIn Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Admin CRUD fields — WS-B.1
  status           ProviderStatus @default(APPLICATION_PENDING)
  kycStatus        KycStatus      @default(NOT_STARTED)
  payoutVerifiedAt DateTime?
  suspendedUntil   DateTime?
  suspendedReason  String?
  strikes          Int            @default(0)
  archivedAt       DateTime?
  archiveReason    String?

  schedule          ProviderSchedule[]
  technicianSkills  TechnicianSkill[]
  technicianCertifications TechnicianCertification[]
  technicianServiceAreas TechnicianServiceArea[]
  technicianAvailability TechnicianAvailability?
  scheduleItems     TechnicianScheduleItem[]
  leads             Lead[]
  matches           Match[]
  jobs              Job[]
  reviews           Review[]
  pushSubscriptions PushSubscription[]
  applications      ProviderApplication[]
  preferredByRequests JobRequest[] @relation("PreferredProvider")
  assignmentHolds   AssignmentHold[]
  matchAttempts     MatchAttempt[]
  selectedDispatchDecisions DispatchDecision[] @relation("DispatchDecisionSelectedProvider")
  providerNotes     ProviderNote[]
  adminCertifications ProviderCertification[]
  equipment         ProviderEquipment[]

  @@map("providers")
}

model ProviderSchedule {
  id         String   @id @default(cuid())
  providerId String
  dayOfWeek  Int      // 0=Sun, 1=Mon, ..., 6=Sat
  startTime  String   // "08:00"
  endTime    String   // "17:00"
  active     Boolean  @default(true)

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, dayOfWeek])
  @@map("provider_schedule")
}

model PushSubscription {
  id         String   @id @default(cuid())
  providerId String
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ─── Provider applications ────────────────────────────────────────────────────

model ProviderApplication {
  id           String            @id @default(cuid())
  providerId   String?           // set after account is created on approval
  phone        String
  name         String
  skills       String[]          @default([])
  serviceAreas String[]          @default([])
  experience   String?           // e.g. "3–5 years" — set on application submit
  availability String?           // e.g. "Any day" or "Mon–Sat" — set on application submit
  evidenceNote String?
  idNumber     String?           // POPIA §26 special personal info — do NOT log, export raw, or include in API responses. Encrypt at rest before GA.
  status       ApplicationStatus @default(PENDING)
  notes        String?           // admin review notes
  reviewedAt   DateTime?
  reviewedById String?
  submittedAt  DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  provider Provider? @relation(fields: [providerId], references: [id])

  @@map("provider_applications")
}

// ─── Job Requests ─────────────────────────────────────────────────────────────
// A customer's initial request. Platform validates and opens it for matching.

model JobRequest {
  id          String           @id @default(cuid())
  customerId  String
  addressId   String?
  category    String           // "plumbing" | "painting" | "garden" | etc.
  title       String           // short description: "Leaking tap in bathroom"
  description String           // full details provided by customer
  requestedWindowStart DateTime?
  requestedWindowEnd DateTime?
  requestedArrivalLatest DateTime?
  estimatedDurationMinutes Int?
  requiredSkillTags String[]   @default([])
  requiredCertificationCodes String[] @default([])
  requiredEquipmentTags String[] @default([])
  requiredVehicleTypes String[] @default([])
  preferredProviderId String?
  assignmentMode AssignmentMode @default(AUTO_ASSIGN)
  customerAcceptedAmount Decimal? @db.Decimal(10, 2)
  customerAcceptedScope String?
  autoCreateBookingOnAssignment Boolean @default(false)
  customerAccessToken String?   @unique
  customerAccessTokenExpiresAt DateTime?
  customerAccessTokenRevokedAt DateTime?
  latestDispatchDecisionId String?
  status      JobRequestStatus @default(PENDING_VALIDATION)
  expiresAt   DateTime?        // if no match within window, mark EXPIRED
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  customer    Customer     @relation(fields: [customerId], references: [id])
  address     Address?     @relation(fields: [addressId], references: [id])
  preferredProvider Provider? @relation("PreferredProvider", fields: [preferredProviderId], references: [id])
  attachments Attachment[]
  leads       Lead[]
  match       Match?
  scheduleItems TechnicianScheduleItem[]
  matchAttempts MatchAttempt[]
  assignmentHolds AssignmentHold[]
  dispatchDecisions DispatchDecision[]

  @@map("job_requests")
}

// ─── Leads ────────────────────────────────────────────────────────────────────
// Platform broadcasts a job request to matched providers.
// First provider to accept the lead gets the match.

model Lead {
  id           String     @id @default(cuid())
  jobRequestId String
  providerId   String
  dispatchDecisionId String?
  matchAttemptId String?
  assignmentHoldId String?
  status       LeadStatus @default(SENT)
  sentAt       DateTime   @default(now())
  respondedAt  DateTime?
  expiresAt    DateTime?  // provider must respond within this window
  reminderSentAt DateTime? // set once when the 1-hour reminder WhatsApp is sent

  jobRequest JobRequest @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  provider   Provider   @relation(fields: [providerId], references: [id])
  dispatchDecision DispatchDecision? @relation(fields: [dispatchDecisionId], references: [id], onDelete: SetNull)
  matchAttempt MatchAttempt? @relation(fields: [matchAttemptId], references: [id], onDelete: SetNull)
  assignmentHold AssignmentHold? @relation(fields: [assignmentHoldId], references: [id], onDelete: SetNull)

  @@unique([jobRequestId, providerId])
  @@map("leads")
}

// ─── Match ────────────────────────────────────────────────────────────────────
// Once a provider accepts a lead, a Match is created linking customer to provider.

model Match {
  id              String      @id @default(cuid())
  jobRequestId    String      @unique
  providerId      String
  status          MatchStatus @default(MATCHED)
  inspectionNeeded Boolean    @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  jobRequest        JobRequest        @relation(fields: [jobRequestId], references: [id])
  provider          Provider          @relation(fields: [providerId], references: [id])
  inspectionSlots   InspectionSlot[]
  quotes            Quote[]
  booking           Booking?

  @@map("matches")
}

// ─── Inspection ───────────────────────────────────────────────────────────────
// Optional pre-quote site visit to assess scope before quoting.

model InspectionSlot {
  id          String           @id @default(cuid())
  matchId     String
  proposedAt  DateTime         // provider proposes a time
  confirmedAt DateTime?        // customer confirms
  completedAt DateTime?
  status      InspectionStatus @default(PROPOSED)
  notes       String?

  match       Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@map("inspection_slots")
}

// ─── Quotes ───────────────────────────────────────────────────────────────────
// Provider's formal quote for the job. Customer approves before booking is created.

model Quote {
  id             String      @id @default(cuid())
  matchId        String
  amount         Decimal     @db.Decimal(10, 2)
  labourCost     Decimal     @db.Decimal(10, 2) @default(0)
  materialsCost  Decimal     @db.Decimal(10, 2) @default(0)
  estimatedHours Float?
  description    String      // what is included in the quoted price
  validUntil     DateTime?
  preferredDate  DateTime?
  postInspection Boolean     @default(false)
  approvalToken  String      @unique
  status         QuoteStatus @default(PENDING)
  approvedAt     DateTime?
  declinedAt     DateTime?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  match   Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  booking Booking?

  @@map("quotes")
}

// ─── Bookings ─────────────────────────────────────────────────────────────────
// Created once a quote is approved. Represents a confirmed, scheduled job.

model Booking {
  id              String        @id @default(cuid())
  matchId         String        @unique
  quoteId         String        @unique
  status          BookingStatus @default(SCHEDULED)
  scheduledDate   DateTime
  scheduledWindow String?       // "09:00-12:00"
  scheduledStartAt DateTime?
  scheduledEndAt   DateTime?
  notes           String?
  cancelReason    String?
  rescheduleCount Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  match    Match    @relation(fields: [matchId], references: [id])
  quote    Quote    @relation(fields: [quoteId], references: [id])
  job      Job?
  payment  Payment?
  invoice  Invoice?
  messages MessageEvent[]
  scheduleItems TechnicianScheduleItem[]

  @@map("bookings")
}

// ─── Jobs (execution) ─────────────────────────────────────────────────────────

model Job {
  id             String    @id @default(cuid())
  bookingId      String    @unique
  providerId     String
  status         JobStatus @default(SCHEDULED)
  notes          String?
  completionNote String?
  arrivedAt      DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  failureReason  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  booking       Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider      Provider         @relation(fields: [providerId], references: [id])
  photos        Attachment[]
  extras        ExtraWork[]
  statusHistory JobStatusEvent[]
  payout        ProviderPayout?

  @@map("jobs")
}

model JobStatusEvent {
  id         String     @id @default(cuid())
  jobId      String
  fromStatus JobStatus?
  toStatus   JobStatus
  actorId    String     // user ID of who triggered the change
  actorRole  String     // 'provider' | 'customer' | 'admin' | 'system'
  notes      String?
  timestamp  DateTime   @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_status_events")
}

model ExtraWork {
  id             String         @id @default(cuid())
  jobId          String
  description    String
  amount         Decimal        @db.Decimal(10, 2)
  status         ApprovalStatus @default(PENDING)
  approvalToken  String         @unique @default(cuid())
  approvedAt     DateTime?
  declinedAt     DateTime?
  approvedByName String?
  createdAt      DateTime       @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("extra_work")
}

// ─── Attachments ──────────────────────────────────────────────────────────────

model Attachment {
  id               String   @id @default(cuid())
  jobId            String?
  inspectionSlotId String?
  jobRequestId     String?
  url              String
  blobKey          String   // Vercel Blob key for deletion
  mimeType         String
  sizeBytes        Int
  label            String?  // "before", "after", "inspection", "receipt"
  caption          String?
  uploadedBy       String   // user ID
  createdAt        DateTime @default(now())

  job            Job?            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  inspectionSlot InspectionSlot? @relation(fields: [inspectionSlotId], references: [id], onDelete: Cascade)
  jobRequest     JobRequest?     @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// ─── Payments & Payouts ───────────────────────────────────────────────────────

model Payment {
  id             String        @id @default(cuid())
  bookingId      String        @unique
  status         PaymentStatus @default(PENDING)
  collectionMode PaymentCollectionMode @default(OFFLINE_RECORDED)
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("ZAR")
  pspProvider    String?       // "peach" | "yoco" | "payfast"
  pspReference   String?
  pspCheckoutId  String?
  checkoutUrl    String?
  paidAt         DateTime?
  failureReason  String?
  refundedAmount Decimal?      @db.Decimal(10, 2)
  refundedAt     DateTime?
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model ProviderPayout {
  id             String       @id @default(cuid())
  jobId          String       @unique
  providerId     String
  grossAmount    Decimal      @db.Decimal(10, 2) // customer paid amount
  commissionRate Decimal      @db.Decimal(5, 4)  // e.g. 0.1500 = 15%
  commissionAmt  Decimal      @db.Decimal(10, 2)
  netAmount      Decimal      @db.Decimal(10, 2) // gross - commission
  status         PayoutStatus @default(PENDING)
  processedAt    DateTime?
  reference      String?      // bank transfer reference
  createdAt      DateTime     @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("provider_payouts")
}

model TechnicianSkill {
  id             String   @id @default(cuid())
  providerId     String
  skillTag       String
  proficiency    Int?
  yearsExperience Float?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, skillTag])
  @@map("technician_skills")
}

model TechnicianCertification {
  id              String              @id @default(cuid())
  providerId      String
  certificationCode String
  certificationName String
  issuingAuthority String?
  status          TechnicianCertificationStatus @default(SELF_DECLARED)
  expiresAt       DateTime?
  verifiedAt      DateTime?
  evidenceUrl     String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, certificationCode])
  @@map("technician_certifications")
}

model TechnicianServiceArea {
  id          String   @id @default(cuid())
  providerId  String
  areaType    TechnicianServiceAreaType @default(SUBURB)
  label       String
  city           String?
  province       String?
  locationNodeId String?
  provinceKey    String?
  cityKey        String?
  regionKey      String?
  suburbKey      String?
  lat            Float?
  lng            Float?
  radiusKm       Float?
  priority       Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  locationNode LocationNode? @relation(fields: [locationNodeId], references: [id])

  @@unique([providerId, locationNodeId])
  @@index([providerId, active])
  @@index([locationNodeId])
  @@index([provinceKey])
  @@index([suburbKey])
  @@map("technician_service_areas")
}

model TechnicianAvailability {
  id                 String   @id @default(cuid())
  providerId         String   @unique
  availabilityState  TechnicianAvailabilityState @default(AVAILABLE)
  nextAvailableAt    DateTime?
  breakUntil         DateTime?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("technician_availability")
}

model TechnicianScheduleItem {
  id                  String   @id @default(cuid())
  providerId          String
  bookingId           String?
  jobRequestId        String?
  assignmentHoldId    String?
  itemType            TechnicianScheduleItemType
  status              TechnicianScheduleItemStatus @default(ACTIVE)
  title               String?
  startAt             DateTime
  endAt               DateTime
  bufferBeforeMinutes Int      @default(15)
  bufferAfterMinutes  Int      @default(15)
  source              String
  locationLabel       String?
  lat                 Float?
  lng                 Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  provider       Provider        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  booking        Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  jobRequest     JobRequest?     @relation(fields: [jobRequestId], references: [id], onDelete: SetNull)
  assignmentHold AssignmentHold? @relation(fields: [assignmentHoldId], references: [id], onDelete: SetNull)

  @@index([providerId, startAt, endAt])
  @@map("technician_schedule_items")
}

model DispatchDecision {
  id                    String   @id @default(cuid())
  jobRequestId          String
  mode                  DispatchMode
  status                DispatchDecisionStatus @default(RANKED)
  initiatedById         String
  initiatedByRole       String
  idempotencyKey        String?
  selectedProviderId    String?
  selectedMatchAttemptId String? @unique
  overrideReason        String?
  retryCount            Int      @default(0)
  nextRetryAt           DateTime?
  scoreWeights          Json     @default("{}")
  consideredCount       Int      @default(0)
  eligibleCount         Int      @default(0)
  rankingSummary        Json?
  filterSummary         Json?
  explanation           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  jobRequest           JobRequest     @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  selectedProvider     Provider?      @relation("DispatchDecisionSelectedProvider", fields: [selectedProviderId], references: [id], onDelete: SetNull)
  selectedMatchAttempt MatchAttempt?  @relation("DispatchDecisionSelectedMatchAttempt", fields: [selectedMatchAttemptId], references: [id], onDelete: SetNull)
  matchAttempts        MatchAttempt[]
  assignmentHolds      AssignmentHold[]
  leads                Lead[]

  @@index([jobRequestId, createdAt])
  @@map("dispatch_decisions")
}

model MatchAttempt {
  id                 String   @id @default(cuid())
  jobRequestId       String
  providerId         String
  dispatchDecisionId String
  attemptNumber      Int
  rankedPosition     Int?
  stage              MatchAttemptStage @default(FILTERED_OUT)
  hardFilterPassed   Boolean @default(false)
  filteredReasonCodes String[] @default([])
  feasibilityNotes   String[] @default([])
  score              Float?
  scoreBreakdown     Json?
  offeredAt          DateTime?
  respondedAt        DateTime?
  responseOutcome    AssignmentResponseOutcome?
  reasonCode         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  jobRequest        JobRequest      @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  provider          Provider        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  dispatchDecision  DispatchDecision @relation(fields: [dispatchDecisionId], references: [id], onDelete: Cascade)
  leads             Lead[]
  assignmentHolds   AssignmentHold[]
  selectedByDispatch DispatchDecision? @relation("DispatchDecisionSelectedMatchAttempt")

  @@unique([dispatchDecisionId, providerId])
  @@index([jobRequestId, rankedPosition])
  @@map("match_attempts")
}

model AssignmentHold {
  id                 String   @id @default(cuid())
  jobRequestId       String
  providerId         String
  dispatchDecisionId String
  matchAttemptId     String
  status             AssignmentHoldStatus @default(ACTIVE)
  offeredAt          DateTime @default(now())
  expiresAt          DateTime
  respondedAt        DateTime?
  releasedAt         DateTime?
  outcomeReasonCode  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  jobRequest       JobRequest       @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  provider         Provider         @relation(fields: [providerId], references: [id], onDelete: Cascade)
  dispatchDecision DispatchDecision @relation(fields: [dispatchDecisionId], references: [id], onDelete: Cascade)
  matchAttempt     MatchAttempt     @relation(fields: [matchAttemptId], references: [id], onDelete: Cascade)
  leads            Lead[]
  scheduleItems    TechnicianScheduleItem[]

  @@index([jobRequestId, status])
  @@map("assignment_holds")
}

model Invoice {
  id          String    @id @default(cuid())
  bookingId   String    @unique
  number      String    @unique
  pdfUrl      String?
  sentAt      DateTime?
  totalAmount Decimal   @db.Decimal(10, 2)
  taxAmount   Decimal?  @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id           String     @id @default(cuid())
  jobId        String
  reviewerType ReviewerType
  customerId   String?    // set when customer reviews provider
  providerId   String?    // set when provider rates customer
  score        Int        // 1-5
  comment      String?
  createdAt    DateTime   @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  provider Provider? @relation(fields: [providerId], references: [id])

  @@unique([jobId, reviewerType])
  @@map("reviews")
}

// ─── Disputes ─────────────────────────────────────────────────────────────────

model Dispute {
  id          String        @id @default(cuid())
  jobId       String
  raisedById  String        // user ID of who raised it
  raisedByRole String       // 'customer' | 'provider'
  reason      String
  status      DisputeStatus @default(OPEN)
  resolution  String?
  resolvedAt  DateTime?
  resolvedById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("disputes")
}

// ─── Messaging ────────────────────────────────────────────────────────────────

model MessageEvent {
  id            String         @id @default(cuid())
  customerId    String?
  bookingId     String?
  channel       MessageChannel
  direction     String         @default("OUTBOUND") // "INBOUND" | "OUTBOUND"
  templateName  String?
  body          String?
  to            String         // phone number or email
  externalId    String?        // WhatsApp message ID (WAMID)
  status        MessageStatus  @default(QUEUED)
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  failureReason String?
  metadata      Json           @default("{}")
  createdAt     DateTime       @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  booking  Booking?  @relation(fields: [bookingId], references: [id])

  @@map("message_events")
}

model InboundWhatsAppMessage {
  id             String   @id @default(cuid())
  externalId     String   @unique
  phone          String
  messageType    String
  body           String?
  payload        Json     @default("{}")
  duplicateCount Int      @default(0)
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  processedAt    DateTime?
  failureReason  String?

  @@index([phone, firstSeenAt])
  @@map("inbound_whatsapp_messages")
}

model WhatsappPreferenceLog {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  field       String   // "whatsappMarketingOptIn" | "whatsappServiceOptIn"
  oldValue    Boolean
  newValue    Boolean
  source      String   // "bot" | "pwa" | "admin" | "webhook" | "import"
  actorId     String?  // admin user id if source=="admin"
  note        String?
  createdAt   DateTime @default(now())

  @@index([customerId, createdAt])
  @@map("whatsapp_preference_logs")
}

// Per-phone conversation session — drives the WhatsApp bot state machine
model Conversation {
  id                String    @id @default(cuid())
  phone             String    @unique // E.164 WhatsApp number — one session per number
  flow              String    // 'idle' | 'job_request' | 'registration' | 'status' | 'help'
  step              String    // current step within the flow
  data              Json      @default("{}") // accumulated session data
  expiresAt         DateTime  // TTL: reset to welcome after 30min inactivity
  timeoutNotifiedAt DateTime? // set once when the inactivity timeout message is sent — deduplication guard
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("conversations")
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorRole  String
  action     String   // e.g. "booking.cancel", "job.reassign", "refund.issue"
  entityType String
  entityId   String
  before     Json?
  after      Json?
  reason     String?  // human-readable justification for the action
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  @@map("audit_logs")
}

model OpsQueueAssignment {
  id             String       @id @default(cuid())
  queueType      OpsQueueType
  entityId       String
  claimedById    String?
  claimedByRole  String?
  claimedByLabel String?
  claimedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([queueType, entityId])
  @@index([queueType, claimedById])
  @@map("ops_queue_assignments")
}

model OnboardingIntake {
  id             String   @id @default(cuid())
  source         String
  sourceRef      String?
  journey        String
  phone          String
  name           String?
  email          String?
  message        String?
  status         String   @default("NEW")
  whatsappOptIn  Boolean  @default(true)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([phone, createdAt])
  @@index([status, createdAt])
  @@map("onboarding_intakes")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum JobRequestStatus {
  PENDING_VALIDATION // just submitted, platform reviewing
  OPEN               // validated, broadcasting leads to providers
  MATCHING           // at least one lead sent, awaiting acceptance
  MATCHED            // a provider accepted — Match created
  EXPIRED            // no provider accepted within the window
  CANCELLED          // customer cancelled before match
}

enum LeadStatus {
  SENT      // sent to provider, awaiting response
  VIEWED    // provider opened the lead
  ACCEPTED  // provider accepted — triggers Match creation
  DECLINED  // provider passed on this job
  EXPIRED   // provider didn't respond in time
}

enum MatchStatus {
  MATCHED                   // provider accepted lead
  INSPECTION_SCHEDULED      // inspection visit arranged
  INSPECTION_COMPLETE       // inspection done, awaiting quote
  QUOTED                    // provider submitted a quote
  QUOTE_APPROVED            // customer approved quote — Booking created
  QUOTE_DECLINED            // customer declined quote
  CANCELLED                 // cancelled at match stage
}

enum AssignmentMode {
  AUTO_ASSIGN
  OPS_REVIEW
}

enum DispatchMode {
  AUTO_ASSIGN
  OPS_REVIEW
  MANUAL_OVERRIDE
}

enum DispatchDecisionStatus {
  RANKED
  OFFERING
  ASSIGNED
  NO_MATCH
  OVERRIDDEN
  CANCELLED
}

enum MatchAttemptStage {
  FILTERED_OUT
  RANKED
  OFFERED
  REJECTED
  TIMED_OUT
  ACCEPTED
  SKIPPED
  OVERRIDDEN
}

enum AssignmentResponseOutcome {
  ACCEPTED
  REJECTED
  TIMED_OUT
  EXPIRED
  OVERRIDDEN
  CANCELLED
}

enum AssignmentHoldStatus {
  ACTIVE
  ACCEPTED
  REJECTED
  EXPIRED
  RELEASED
  CANCELLED
}

enum TechnicianCertificationStatus {
  SELF_DECLARED
  EVIDENCE_UPLOADED
  REVIEWED
  VERIFIED
  EXPIRED
}

enum LocationNodeType {
  PROVINCE
  CITY
  REGION
  SUBURB
}

enum TechnicianServiceAreaType {
  SUBURB
  CITY
  REGION
  RADIUS
  CUSTOM
}

enum TechnicianAvailabilityState {
  AVAILABLE
  BUSY
  PAUSED
  OFFLINE
}

enum TechnicianScheduleItemType {
  BOOKING
  BREAK
  MANUAL_BLOCK
  ASSIGNMENT_HOLD
}

enum TechnicianScheduleItemStatus {
  ACTIVE
  RELEASED
  CANCELLED
}

enum OpsQueueType {
  VALIDATION
  DISPATCH
  QUOTE_APPROVAL
  FIELD_EXCEPTION
  DISPUTE
  PAYMENT_FOLLOW_UP
  PROVIDER_ONBOARDING
}

enum InspectionStatus {
  PROPOSED   // provider proposed a time
  CONFIRMED  // customer confirmed the slot
  COMPLETED  // inspection done
  CANCELLED  // cancelled before completion
}

enum QuoteStatus {
  PENDING   // submitted by provider, awaiting customer decision
  APPROVED  // customer approved — Booking created
  DECLINED  // customer declined
  EXPIRED   // customer didn't respond in time
  REVISED   // provider submitted a new version
}

enum BookingStatus {
  SCHEDULED   // confirmed, date set
  RESCHEDULED // moved to a new date
  CANCELLED   // cancelled after booking
  COMPLETED   // job finished
}

enum JobStatus {
  SCHEDULED         // booking confirmed, job not started
  EN_ROUTE          // provider travelling to site
  ARRIVED           // provider on site
  STARTED           // work in progress
  PAUSED            // paused (waiting for materials, etc.)
  AWAITING_APPROVAL // extra work submitted, waiting for customer
  PENDING_COMPLETION_CONFIRMATION // work done, customer needs to confirm
  COMPLETED         // customer confirmed complete
  CANCELLED         // booking/job cancelled before completion
  FAILED            // job could not be completed
  CALLBACK_REQUIRED // provider flagged need for follow-up
}

enum PaymentStatus {
  PENDING
  AUTHORISED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentCollectionMode {
  OFFLINE_RECORDED
  PLATFORM_CHECKOUT
}

enum PayoutStatus {
  PENDING    // payment received, payout not yet processed
  PROCESSING // transfer initiated
  PAID       // funds transferred to provider
  FAILED     // transfer failed
  ON_HOLD    // held due to dispute
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DECLINED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MessageChannel {
  WHATSAPP
  EMAIL
  SMS
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum ReviewerType {
  CUSTOMER // customer reviewing the provider
  PROVIDER // provider rating the customer
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_CUSTOMER // resolved in customer's favour
  RESOLVED_PROVIDER // resolved in provider's favour
  RESOLVED_SPLIT    // partial refund / split resolution
  CLOSED
}

// ─── WS-B.1 Enums ─────────────────────────────────────────────────────────────

enum Role {
  OPS
  FINANCE
  TRUST
  ADMIN
  OWNER
}

enum CustomerInternalFlag {
  VIP
  FRAUD_RISK
  DISPUTE_HISTORY
  LATE_PAYMENT
  WATCHLIST
  LOYALTY_MEMBER
}

enum CustomerChannel {
  WHATSAPP
  PWA
  REFERRAL
  IMPORT
}

enum KycStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
  EXPIRED
}

enum ProviderStatus {
  APPLICATION_PENDING
  UNDER_REVIEW
  ACTIVE
  SUSPENDED
  ARCHIVED
  BANNED
}

// ─── WS-B.1 Models ────────────────────────────────────────────────────────────

model AdminUser {
  id          String    @id @default(cuid())
  userId      String    @unique // Supabase auth user ID
  email       String    @unique
  name        String
  role        Role      @default(OPS)
  active      Boolean   @default(true)
  invitedAt   DateTime  @default(now())
  invitedById String?
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  invitedBy   AdminUser?  @relation("AdminInvitedBy", fields: [invitedById], references: [id])
  invitees    AdminUser[] @relation("AdminInvitedBy")
  auditEvents AdminAuditEvent[]

  @@map("admin_users")
}

model AdminAuditEvent {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // e.g. "customer.block", "provider.suspend", "flag.toggle"
  entityType String
  entityId   String
  before     Json?
  after      Json?
  metadata   Json     @default("{}")
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId, timestamp])
  @@index([entityType, entityId])
  @@map("admin_audit_events")
}

model FeatureFlag {
  key             String   @id
  enabled         Boolean  @default(false)
  enabledForUsers String[] @default([])
  description     String?
  updatedAt       DateTime @updatedAt

  @@map("feature_flags")
}

model Category {
  id                  String                        @id @default(cuid())
  slug                String                        @unique
  label               String
  description         String?
  active              Boolean                       @default(true)
  bookingOnAssignment Boolean                       @default(false)
  regulated           Boolean                       @default(false)
  sortOrder           Int                           @default(0)
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  requiredCertifications CategoryRequiredCertification[]
  requiredEquipment      CategoryRequiredEquipment[]
  requiredVehicleTypes   CategoryRequiredVehicleType[]

  @@index([active, sortOrder])
  @@map("categories")
}

model CategoryRequiredCertification {
  id         String   @id @default(cuid())
  categoryId String
  code       String
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, code])
  @@index([code])
  @@map("category_required_certifications")
}

model CategoryRequiredEquipment {
  id         String   @id @default(cuid())
  categoryId String
  tag        String
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, tag])
  @@index([tag])
  @@map("category_required_equipment")
}

model CategoryRequiredVehicleType {
  id         String   @id @default(cuid())
  categoryId String
  vehicleType String
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, vehicleType])
  @@index([vehicleType])
  @@map("category_required_vehicle_types")
}

model CustomerMergeEvent {
  id               String    @id @default(cuid())
  sourceCustomerId String?
  targetCustomerId String?
  executedById     String
  reason           String
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now())

  sourceCustomer Customer? @relation("CustomerMergeSource", fields: [sourceCustomerId], references: [id], onDelete: SetNull)
  targetCustomer Customer? @relation("CustomerMergeTarget", fields: [targetCustomerId], references: [id], onDelete: SetNull)

  @@index([sourceCustomerId, createdAt])
  @@index([targetCustomerId, createdAt])
  @@map("customer_merge_events")
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  authorId   String   // admin user ID who wrote the note
  body       String
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@map("customer_notes")
}

model ProviderNote {
  id         String   @id @default(cuid())
  providerId String
  authorId   String   // admin user ID who wrote the note
  body       String
  pinned     Boolean  @default(false)
  reasonCode String?
  strikeDelta Int     @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, createdAt])
  @@map("provider_notes")
}

model ProviderCertification {
  id               String    @id @default(cuid())
  providerId       String
  name             String
  issuingAuthority String?
  certNumber       String?
  issuedAt         DateTime?
  expiresAt        DateTime?
  documentUrl      String?
  verifiedAt       DateTime?
  verifiedById     String?   // admin user ID who verified
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_certifications")
}

model ProviderEquipment {
  id           String   @id @default(cuid())
  providerId   String
  label        String
  category     String?
  serialNumber String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_equipment")
}
