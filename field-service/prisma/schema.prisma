// ─── Matching engine v2 — performance foundations ────────────────────────────
// These three models support near real-time dispatch without full-table scans.

// Tracks provider online/offline state updated by app heartbeat (every 2 min).
// Separated from Provider to keep the hot-path write narrow and fast.
model ProviderLiveStatus {
  providerId       String    @id
  isOnline         Boolean   @default(false)
  availabilityMode String    @default("OFFLINE") // ONLINE | ONLINE_LIMITED | OFFLINE | BREAK
  activeJobCount   Int       @default(0)
  lastHeartbeatAt  DateTime?
  lastLocationLat  Float?
  lastLocationLng  Float?
  lastLocationAt   DateTime?
  updatedAt        DateTime  @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([isOnline])
  @@index([lastLocationLat, lastLocationLng])
  @@map("provider_live_status")
}

// Precomputed index of eligible providers per (category slug × location node).
// Rebuilt on provider profile change and every 5 min by cron.
// Enables O(1) candidate shortlisting instead of full provider scan.
model CandidatePool {
  id             String   @id @default(cuid())
  categorySlug   String
  locationNodeId String?
  provinceKey    String?
  providerId     String
  scoreBase      Float    @default(0) // reliability + skill signal, not travel-adjusted
  lastRefreshed  DateTime @default(now())

  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  locationNode LocationNode? @relation(fields: [locationNodeId], references: [id], onDelete: Cascade)

  @@unique([categorySlug, locationNodeId, providerId])
  @@index([categorySlug, locationNodeId])
  @@index([categorySlug, provinceKey])
  @@map("candidate_pool")
}

// Tracks provider active workload to prevent overloading.
// activeHolds incremented on AssignmentHold creation, decremented on resolution.
model ProviderCapacity {
  providerId    String   @id
  activeHolds   Int      @default(0)
  activeJobs    Int      @default(0)
  maxConcurrent Int      @default(2)
  updatedAt     DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_capacity")
}

