model DispatchDecision {
  id                     String                 @id @default(cuid())
  jobRequestId           String
  mode                   DispatchMode
  status                 DispatchDecisionStatus @default(RANKED)
  initiatedById          String
  initiatedByRole        String
  idempotencyKey         String?
  selectedProviderId     String?
  selectedMatchAttemptId String?                @unique
  overrideReason         String?
  retryCount             Int                    @default(0)
  nextRetryAt            DateTime?
  scoreWeights           Json                   @default("{}")
  consideredCount        Int                    @default(0)
  eligibleCount          Int                    @default(0)
  rankingSummary         Json?
  filterSummary          Json?
  explanation            String?
  alternativeSlotOptions Json? // SlotOption[] — stored for alternative-slot WA negotiation
  // Aggregated request-level reason when status='NO_MATCH'. NULL on dispatch.
  // INSUFFICIENT_REQUEST_DATA | NO_LOCATION_MATCH | NO_SKILL_MATCH_IN_LOCATION | NO_APPROVED_PROVIDER | NO_MATCH
  noMatchReason          String?
  // Per-stage funnel counts: { locationCandidates, skillCandidates, eligibleCount, rankedCount }
  stageCounts            Json?
  // Retry/give-up policy classification for NO_MATCH decisions.
  // EMPTY_POOL | STRUCTURAL | TRANSIENT
  failureClass           String?
  // Request-level normalized policy reason, e.g. NO_LOCATION_MATCH or RESERVATION_FAILED.
  primaryReason          String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  jobRequest           JobRequest       @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  selectedProvider     Provider?        @relation("DispatchDecisionSelectedProvider", fields: [selectedProviderId], references: [id], onDelete: SetNull)
  selectedMatchAttempt MatchAttempt?    @relation("DispatchDecisionSelectedMatchAttempt", fields: [selectedMatchAttemptId], references: [id], onDelete: SetNull)
  matchAttempts        MatchAttempt[]
  assignmentHolds      AssignmentHold[]
  leads                Lead[]

  @@index([jobRequestId, createdAt])
  @@index([noMatchReason, createdAt])
  @@index([failureClass, createdAt])
  @@index([primaryReason, createdAt])
  @@map("dispatch_decisions")
}

