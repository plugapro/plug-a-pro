// ─── Enums ────────────────────────────────────────────────────────────────────

enum OtpPurpose {
  LOGIN
  SIGNUP
  BOOKING_CONFIRMATION
  PAYMENT_CONFIRMATION
  TECHNICIAN_ACCESS
  PROFILE_CHANGE
}

enum OtpChallengeStatus {
  REQUESTED
  SENT
  VERIFIED
  EXPIRED
  CANCELLED
  REPORTED_UNREQUESTED
  FAILED
}

enum SecurityEventType {
  OTP_REPORTED_UNREQUESTED
  OTP_RATE_LIMIT_EXCEEDED
  OTP_VERIFICATION_FAILED_REPEATEDLY
  OTP_DELIVERY_REFUSED_DURING_LOCK
  ACCOUNT_LOCKED
  STEP_UP_COMPLETED
  LOCK_CLEARED_BY_ADMIN
  WEBHOOK_AMBIGUOUS_REFERENCE_RESOLUTION
  WEBHOOK_SIGNATURE_INVALID_REPEATED
  IDENTITY_VERIFICATION_PILOT_BREACH
}

enum SecuritySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SecurityEventStatus {
  NEW
  ACKNOWLEDGED
  RESOLVED
  FALSE_POSITIVE
}

enum SecuritySourceChannel {
  WHATSAPP_BUTTON
  PWA_LINK
  ADMIN
  SYSTEM
}

enum JobRequestStatus {
  PENDING_VALIDATION // just submitted, platform reviewing
  OPEN // validated, broadcasting leads to providers
  MATCHING // at least one lead sent, awaiting acceptance
  SHORTLIST_READY // interested providers are ready for customer comparison
  PROVIDER_CONFIRMATION_PENDING // customer selected a provider, awaiting provider final acceptance
  ACCEPTED_LOCKED // selected provider accepted after credit was applied; MVP1 final state
  MATCHED // a provider accepted — Match created
  EXPIRED // no provider accepted within the window
  CANCELLED // customer cancelled before match
}

enum LeadStatus {
  SEND_PENDING // customer selected provider; WhatsApp send is being attempted
  SEND_FAILED // customer selected provider; WhatsApp send failed and can be retried
  SENT // sent to provider, awaiting response
  VIEWED // provider opened the lead
  INTERESTED // Qualified Shortlist: provider expressed free interest with rate/arrival
  SHORTLISTED // Qualified Shortlist: included in customer-visible shortlist
  CUSTOMER_SELECTED // Qualified Shortlist: customer selected this provider; awaiting final acceptance
  PROVIDER_ACCEPTED // selected provider accepted; awaiting credit application/unlock
  CREDIT_REQUIRED // selected provider accepted but does not currently have enough credits
  CREDIT_APPLIED // selected provider credit has been deducted; awaiting accepted lock
  ACCEPTED_LOCKED // credit applied and selected lead/request are locked; MVP1 final state
  SUPERSEDED // Qualified Shortlist: customer chose another shortlisted provider
  ACCEPTED // provider accepted — triggers Match creation
  DECLINED // provider passed on this job
  EXPIRED // provider didn't respond in time
  CANCELLED // customer cancelled before final acceptance
}

enum LeadUnlockStatus {
  UNLOCKED
  REFUNDED
  DISPUTED
  REVERSED
}

enum LeadUnlockDisputeReason {
  INVALID_CUSTOMER_NUMBER
  DUPLICATE_LEAD
  WRONG_CATEGORY
  WRONG_LOCATION
  CUSTOMER_DID_NOT_REQUEST
  CANCELLED_BEFORE_UNLOCK
}

enum LeadUnlockDisputeStatus {
  OPEN
  APPROVED
  REJECTED
}

enum CompletionCheckStatus {
  SENT
  YES
  NO_RESCHEDULED
  NO_NOT_FINISHED
  NO_DIDNT_SHOW
  ADMIN_FLAGGED
}

enum MatchStatus {
  MATCHED // provider accepted lead
  INSPECTION_SCHEDULED // inspection visit arranged
  INSPECTION_COMPLETE // inspection done, awaiting quote
  QUOTED // provider submitted a quote
  QUOTE_APPROVED // customer approved quote — Booking created
  QUOTE_DECLINED // customer declined quote
  CANCELLED // cancelled at match stage
}

enum AssignmentMode {
  AUTO_ASSIGN
  OPS_REVIEW
}

enum DispatchMode {
  AUTO_ASSIGN
  OPS_REVIEW
  MANUAL_OVERRIDE
}

enum DispatchDecisionStatus {
  RANKED
  OFFERING
  ASSIGNED
  NO_MATCH
  OVERRIDDEN
  CANCELLED
}

enum MatchAttemptStage {
  FILTERED_OUT
  RANKED
  OFFERED
  REJECTED
  TIMED_OUT
