// Per-phone conversation session — drives the WhatsApp bot state machine
model Conversation {
  id                String    @id @default(cuid())
  phone             String    @unique // E.164 WhatsApp number — one session per number
  isTestSession     Boolean   @default(false)
  cohortName        String?
  flow              String // 'idle' | 'job_request' | 'registration' | 'status' | 'help'
  step              String // current step within the flow
  data              Json      @default("{}") // accumulated session data
  expiresAt         DateTime // TTL: reset to welcome after 30min inactivity
  timeoutNotifiedAt DateTime? // set once when the inactivity timeout message is sent — deduplication guard
  recoveryClaimedAt DateTime? // provider-onboarding recovery claim lock (epoch=in-flight, real ts=sent). Separate from timeoutNotifiedAt so the inactivity-timeout cron's dedup guard doesn't block manual recovery — see provider-onboarding-recovery.ts
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  resumeTokens ProviderResumeToken[]

  @@map("conversations")
}

/// Server-only table accessed exclusively via Prisma's service role.
/// RLS is enabled at the table level but no policies exist intentionally —
/// PostgREST anon/authenticated roles have no access. Do not add direct
/// Supabase JS reads against this table.
model ProviderResumeToken {
  id                  String    @id @default(cuid())
  tokenHash           String    @unique // sha256(rawToken) hex; raw never stored
  conversationId      String
  phone               String
  issuedByAdminUserId String
  issuedAt            DateTime  @default(now())
  expiresAt           DateTime
  usedAt              DateTime?
  revokedAt           DateTime?
  revokedReason       String?
  source              String

  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  issuedByAdmin AdminUser    @relation(fields: [issuedByAdminUserId], references: [id])

  @@index([conversationId])
  @@index([phone, expiresAt])
  @@map("provider_resume_tokens")
}

