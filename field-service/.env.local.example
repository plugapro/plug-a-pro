# ─── Venture identity ─────────────────────────────────────────────────────────
# Slug for this specific service business (used as tenant identifier in single-tenant mode)
BUSINESS_SLUG=plug-a-pro

# Multi-tenant platform mode — set to "true" if running a shared platform
# In this mode, tenant is resolved from subdomain
MULTI_TENANT_MODE=false

# ─── Supabase (database + auth) ───────────────────────────────────────────────
# Get these from your Supabase project dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (Supabase pooler URL for serverless)
# connection_limit=5 caps concurrent connections per Vercel function instance — critical to prevent
# Supabase free-tier connection exhaustion under concurrent requests (default Prisma pool is 10).
DATABASE_URL=postgres://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5

# ─── Vercel AI Gateway (OIDC — provisioned by `vercel env pull`) ──────────────
# Run: vercel link → enable AI Gateway in dashboard → vercel env pull
VERCEL_OIDC_TOKEN=

# ─── Vercel Blob (file storage for job photos, invoices) ─────────────────────
# Auto-provisioned by Vercel → Storage → Blob → Connect to project
BLOB_READ_WRITE_TOKEN=

# ─── WhatsApp Business Platform (Meta Cloud API) ─────────────────────────────
# See: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# 1. Create a Facebook App → Add WhatsApp product
# 2. Generate a permanent access token with whatsapp_business_messaging permission
# 3. Find your Phone Number ID in the WhatsApp API → Getting Started page
# 4. Set VERIFY_TOKEN to any random string — used to verify webhook setup
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-random-webhook-verify-token
# App Secret from your Facebook App dashboard → Settings → Basic → App Secret
# REQUIRED — if unset, verifyMetaSignature() rejects ALL inbound POST requests with 403
WHATSAPP_APP_SECRET=your-facebook-app-secret

# ─── Payments (PSP — PayFast for South Africa) ────────────────────────────────
# PayFast: https://developers.payfast.co.za/docs
# Get credentials from your PayFast merchant dashboard → Integration → Merchant Details
PSP_PROVIDER=payfast
# Set to "checkout" to enable real online payment collection.
# IMPORTANT: defaults to "bypass" (no payment collected) if unset — must be set explicitly in production.
PAYMENT_COLLECTION_MODE=checkout
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
# Passphrase is optional but strongly recommended — set in PayFast dashboard → Security
PAYFAST_PASSPHRASE=your-passphrase
# Set to "true" for PayFast sandbox testing (uses sandbox.payfast.co.za)
PAYFAST_SANDBOX=true

# ─── Pay@ provider wallet top-ups ─────────────────────────────────────────────
# Pay@Go dashboard: https://go.payat.co.za/app/secure/business/settings
PAYAT_CLIENT_ID=your-payat-client-id
PAYAT_CLIENT_SECRET=your-payat-client-secret
PAYAT_MERCHANT_ID=418856
# The short identifier for your Pay@ merchant account (e.g. plug-a-pro).
# Found in the Pay@Go dashboard → Settings. REQUIRED — every RTP call will fail without it.
PAYAT_MERCHANT_IDENTIFIER=your-payat-merchant-identifier
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYAT_WEBHOOK_SECRET=your-64-char-hex-webhook-secret
# YAPI v1 base URL — do NOT use /api/v1 (that is the legacy endpoint)
PAYAT_API_BASE=https://go.payat.co.za/yapi/v1
# OAuth token URL lives outside /yapi/v1 per Pay@ Swagger.
PAYAT_TOKEN_URL=https://go.payat.co.za/yapi/oauth/token
# Required OAuth scope for provider wallet RTP create.
PAYAT_SCOPES=rtp:create:single
# Optional: fixed service fee in cents added to the Pay@ barcode amount.
# Covers the Pay@Go merchant fee (3.5%, min R7). Default 700 (R7) if unset.
PAYAT_MERCHANT_FEE_FIXED_CENTS=700

# Pay@Go RTP for booking/job payment requests (separate from provider top-up flow)
PAYAT_GO_BASE_URL=https://go.payat.co.za/yapi/v1
PAYAT_GO_CLIENT_ID=your-payat-go-client-id
PAYAT_GO_CLIENT_SECRET=your-payat-go-client-secret
PAYAT_GO_GRANT_TYPE=client_credentials
# Use the exact scope string(s) enabled on your merchant credentials.
PAYAT_GO_SCOPES=rtp:create:single rtp:cancel:single rtp:read
PAYAT_GO_WEBHOOK_SECRET=your-payat-go-webhook-secret
PAYAT_GO_CALLBACK_SECRET=your-payat-go-callback-secret
PAYAT_GO_ENABLED=false
PAYAT_GO_MOCK_MODE=true
PAYAT_GO_CREATE_LIMIT_PER_BOOKING_USER_HOUR=12
PAYAT_GO_STATUS_LIMIT_PER_BOOKING_USER_HOUR=120
PAYAT_GO_CANCEL_LIMIT_PER_BOOKING_USER_HOUR=20
PAYAT_GO_CALLBACK_LIMIT_PER_REFERENCE_HOUR=120
PAYAT_GO_RETRY_MAX_ATTEMPTS=3
PAYAT_GO_RETRY_BASE_DELAY_MS=200

# ─── Maps (Google Maps API) ────────────────────────────────────────────────────
# Enable: Maps Embed API, Places API (New), Geocoding API
# https://console.cloud.google.com/apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── App URLs ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL is the client-visible base URL — baked into the browser bundle by Next.js.
# In local development this is http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# APP_PUBLIC_URL is the server-side-only canonical public URL used when generating links in
# outbound WhatsApp messages (provider approval, lead preview, wallet notifications, etc.).
# In production this MUST be the public domain — never localhost.
#
# Why a separate variable?
#   NEXT_PUBLIC_APP_URL is bundled into the client at build time and is typically correct on
#   Vercel (set to the deployment URL). However, local scripts that send real WhatsApp messages
#   (e.g. scripts/manual-approve-provider.ts) run against the local .env.local which has
#   localhost, causing WhatsApp links to be broken. Set APP_PUBLIC_URL to the production domain
#   in those environments to override.
#
# Required in production: https://app.plugapro.co.za
# Can be left blank in local dev (falls back to NEXT_PUBLIC_APP_URL = localhost)
APP_PUBLIC_URL=

# ─── Auth secret ──────────────────────────────────────────────────────────────
# Used to sign session tokens — generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-min-32-chars

# ─── Admin notifications ───────────────────────────────────────────────────────
# WhatsApp number to notify when a new technician application is submitted
# Optional — if not set, admin must check /admin/applications manually
# Format: E.164 e.g. +27821234567
ADMIN_WHATSAPP_NUMBER=

# Customer-facing support WhatsApp number (official Plug A Pro line)
# Used on error pages, not-found, auth pages, leads access, credit terms
# Format: E.164 without the + prefix for wa.me links (the code strips non-digits)
SUPPORT_WHATSAPP_NUMBER=+27693552447
# Same number exposed to the browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPPORT_WHATSAPP_NUMBER=+27693552447

# ─── Cron job security secret ──────────────────────────────────────────────────
# Vercel sets this automatically on pro/enterprise plans.
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret

# Direct Postgres URL (for prisma migrate — bypasses connection pooler)
# Same as DATABASE_URL but without ?pgbouncer=true and on port 5432
DIRECT_URL=postgres://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# ─── Notifications (optional) ─────────────────────────────────────────────────
# Web Push notifications for technician job alerts
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@plugapro.co.za

# ─── OTP delivery via WhatsApp ────────────────────────────────────────────────
# Supabase Auth Send SMS Hook → /api/auth/hooks/send-sms
# Configure the hook URL and this secret in Supabase dashboard →
# Authentication → Hooks → Send SMS hook. Format: "v1,whsec_<base64>"
# (Standard Webhooks). Used to verify the webhook-signature header on every
# call. Required before the auth.otp.whatsapp flag is flipped on.
SUPABASE_AUTH_HOOK_SECRET=

# ─── Rate limiter (Upstash Redis via Vercel Marketplace) ──────────────────────
# Auto-injected when the Upstash Redis integration is linked to the project
# under Vercel → Storage. Used by the OTP send + verify rate limits.
# Optional in local dev: rate limiting fails open with a console warning when
# these are unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
