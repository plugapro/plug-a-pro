{
  "name": "@plug-a-pro/field-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:journeys": "vitest run __tests__/integration/cross-channel-release-harness.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "seed:locations": "tsx scripts/seed-locations.ts",
    "audit:locations": "tsx scripts/audit-locations.ts",
    "export:locations": "tsx scripts/export-locations.ts",
    "db:probe-migrations": "tsx scripts/probe-migration-state.ts",
    "db:backfill": "tsx scripts/backfill-location-nodes.ts",
    "db:backfill:qualified-shortlist": "tsx scripts/backfill-qualified-shortlist-foundation.ts",
    "db:backfill-cases": "tsx scripts/backfill-cases.ts",
    "seed:test-leads": "tsx --env-file=.env.local scripts/seed-west-rand-test-leads.ts --dry-run",
    "seed:test-leads:commit": "ALLOW_TEST_DATA_IMPORT=true tsx --env-file=.env.local scripts/seed-west-rand-test-leads.ts --commit",
    "seed:test-leads:reset": "ALLOW_TEST_DATA_IMPORT=true tsx --env-file=.env.local scripts/seed-west-rand-test-leads.ts --commit --reset-existing=true",
    "seed:test-leads:requests-only": "ALLOW_TEST_DATA_IMPORT=true tsx --env-file=.env.local scripts/seed-west-rand-test-leads.ts --commit --requests-only",
    "ops:fast-match:kpi-report": "tsx scripts/report-fast-match-kpis.ts",
    "ops:whatsapp:live-harness": "tsx scripts/run-live-whatsapp-harness.ts",
    "db:studio": "prisma studio",
    "db:wallet-schema-drift": "tsx scripts/wallet-schema-drift-repair.ts",
    "whatsapp:templates:audit": "node scripts/register-whatsapp-templates.mjs --audit-coverage",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.140",
    "@hookform/resolvers": "^5.0.1",
    "@prisma/client": "^6.5.0",
    "@radix-ui/react-avatar": "^1.1.6",
    "@radix-ui/react-dialog": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.11",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-select": "^2.2.4",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.6",
    "@radix-ui/react-tooltip": "^1.2.4",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/supabase-js": "^2.100.0",
    "@vercel/blob": "^2.3.3",
    "ai": "^6.0.138",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "geist": "^1.7.0",
    "lucide-react": "^1.6.0",
    "mermaid": "^11.13.0",
    "motion": "^12.38.0",
    "next": "^16.2.1",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.56.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "prisma": "^6.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
