flowchart TD
  subgraph Inputs["Reconciliation Inputs"]
    I1["[DB] Provider and approved ProviderApplication records"]
    I2["[DB] ProviderPromoAward records"]
    I3["[DB] PaymentIntent records"]
    I4["[DB] WalletLedgerEntry records"]
