    I6["[DB] LeadUnlock records"]
    I7["[DB] LeadUnlockDispute records"]
    I8["[Payment] Bank statement / PayFast ITN references"]
    I9["[Audit] AdminAuditEvent and auditLog rows"]
  end

  subgraph Checks["Manual / Query-Based Checks"]
    C1["[Ops] Approved providers should have at most one MOBILE_VERIFIED award"]
    C2["[Ops] PaymentIntent CREDITED should have TOPUP_CREDIT ledger entry"]
    C3["[Ops] PayFast intent should have creditedLedgerEntryId"]
    C4["[Ops] LeadUnlock should have matching LEAD_UNLOCK_DEBIT ledger entries"]
    C5["[Ops] Refund dispute should have LEAD_REFUND_CREDIT entries"]
    C6["[Ops] Wallet balance should equal latest ledger balance snapshot"]
    C7["[Ops] Admin adjustments should have reason and audit event"]
  end

  subgraph Exceptions["Exception Types"]
    E1["[Exception] Duplicate promo grant"]
    E2["[Exception] Credited payment without ledger"]
    E3["[Exception] Ledger without PaymentIntent/LeadUnlock reference"]
    E4["[Exception] Wallet cached balance drift"]
    E5["[Exception] Unlock without debit or debit without unlock"]
    E6["[Exception] Test cohort ledger flag or cohort mismatch"]
    E7["[Exception] Reversal/expiry placeholders not operational"]
  end

  subgraph Outputs["Current Outputs"]
    O1["[Worker Portal OTP] Provider credit ledger statement"]
    O2["[Admin] Provider wallets page"]
    O3["[Admin] Provider credit payments page"]
    O4["[Admin] Lead unlock disputes page"]
    O5["[Backend] buildProviderCreditReconciliationReport outputs issues"]
    O6["[Gap] No scheduled finance reconciliation job or admin exception dashboard yet"]
  end

