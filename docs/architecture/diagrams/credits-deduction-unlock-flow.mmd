flowchart TD
  subgraph Channels["WhatsApp / PWA Channels"]
    C1["[WhatsApp] Provider taps Unlock & Accept"]
    C2["[PWA Signed Link] Provider taps Unlock or Accept"]
    C3["[Worker Portal OTP] Provider lead action"]
  end

  subgraph AcceptService["Backend Accept / Unlock Service"]
    A1["[Backend] matching-engine.acceptLead"]
    A2["[Backend] acceptAssignmentOffer transaction"]
    A3{"[Backend] Lead exists, belongs to provider, hold active, not expired?"}
    A4{"[Backend] Provider active, verified, status ACTIVE?"}
    A5{"[Backend] Existing Match for another provider?"}
    A6["[Backend] unlockLeadForProviderInTransaction"]
  end

  subgraph UnlockLedger["Lead Unlock and Ledger"]
    U1{"[Backend] LeadUnlock already exists?"}
    U2{"[Backend] Same provider?"}
    U3["[Backend] Return alreadyUnlocked with no ledger write"]
    U4["[Wallet] Read paid + promo credit balances"]
    U5{"[Wallet] Total credits >= 1 and wallet ACTIVE?"}
    U6["[DB] Create LeadUnlock before debit"]
    U7["[Wallet] Optimistic updateMany decrements promo first, then paid"]
    U8{"[Wallet] Balance update count = 1?"}
    U9["[Ledger] LEAD_UNLOCK_DEBIT entries"]
    U10["[DB] Update LeadUnlock creditTypeBreakdown"]
    U11["[Error] Insufficient credits, suspended wallet, or concurrent mutation"]
  end

  subgraph Assignment["Assignment Commit"]
    M1["[DB] Lead status ACCEPTED"]
    M2["[DB] AssignmentHold ACCEPTED"]
    M3["[DB] Match created"]
    M4["[DB] JobRequest status MATCHED"]
    M5["[DB] Other offers expired or released"]
    M6["[Audit] lead.accept audit log"]
  end

  subgraph Notifications["Post-Commit Notifications"]
    N1["[WhatsApp] notifyPostMatchAcceptance"]
    N2["[Customer Notification] Provider name and contact released"]
    N3["[Provider Notification] Customer details and View Job link"]
    N4["[Logs] Notification failure logged, accept remains committed"]
    N5["[Wallet Notification] Lead unlocked and low-balance notifications"]
  end

  subgraph Decline["Decline Path"]
    D1["[WhatsApp/PWA] Provider declines lead"]
    D2["[Backend] rejectAssignmentOffer"]
    D3["[DB] Lead DECLINED and hold REJECTED"]
    D4["[Ledger] No credit debit"]
    D5["[Backend] Offer next ranked candidate"]
  end

  C1 --> A1
  C2 --> A1
  C3 --> A1
  A1 --> A2 --> A3
  A3 -- "No" --> U11
  A3 -- "Yes" --> A4
  A4 -- "No" --> U11
  A4 -- "Yes" --> A5
  A5 -- "Yes" --> U11
  A5 -- "No" --> A6 --> U1
  U1 -- "Yes" --> U2
  U2 -- "Yes" --> U3 --> M1
  U2 -- "No" --> U11
  U1 -- "No" --> U4 --> U5
  U5 -- "No" --> U11
  U5 -- "Yes" --> U6 --> U7 --> U8
  U8 -- "No" --> U11
  U8 -- "Yes" --> U9 --> U10 --> M1
  M1 --> M2 --> M3 --> M4 --> M5 --> M6 --> N1
  N1 --> N2
  N1 --> N3
  N1 --> N4
  U10 --> N5

  C1 --> D1
  C2 --> D1
  D1 --> D2 --> D3 --> D4 --> D5

  classDef error fill:#f8d7da,stroke:#842029,color:#58151c;
  class U11,N4 error;
