flowchart TD
  A["[Provider] Onboard or operate as approved provider"]

  subgraph Onboarding["Onboarding / Promo Credits"]
    O1["[Admin/System] Provider application approved"]
    O2["[Backend] awardMobileVerifiedPromoCreditsInTransaction"]
    O3{"[Backend] ProviderPromoAward exists for MOBILE_VERIFIED?"}
    O4["[Ledger] PROMO_CREDIT ledger entry"]
    O5["[Wallet] Increment promoCreditBalance"]
    O6["[Backend] Skip duplicate award"]
  end

  subgraph TopUp["Credit Purchase / Top-up"]
    T1["[Worker Portal OTP] Provider opens Credits"]
    T2{"[Provider] Top-up method"}
    T3["[Backend] Create PaymentIntent for manual EFT"]
    T4["[Payment/Ops] Provider pays bank deposit and uploads proof"]
    T5["[Admin/Ops] Reconcile statement and credit wallet"]
    T6["[Backend] Create PayFast PaymentIntent"]
    T7["[Payment] Provider completes PayFast checkout"]
    T8["[Payment] Verified PayFast ITN"]
    T9["[Ledger] TOPUP_CREDIT paid ledger entry"]
    T10["[Wallet] Increment paidCreditBalance"]
    T11["[Ledger] Optional FIRST_TOPUP PROMO_CREDIT"]
  end

  subgraph Balance["Balance and Statement"]
    B1["[Wallet] ProviderWallet cached balances"]
    B2["[Ledger] WalletLedgerEntry history"]
    B3["[Worker Portal OTP] Provider credit statement"]
    B4["[Admin] Provider wallet detail"]
  end

  subgraph LeadUnlock["Lead Unlock / Acceptance"]
    L1["[WhatsApp/PWA] Provider accepts or unlocks lead"]
    L2["[Backend] Check provider, lead, wallet status"]
    L3{"[Ledger] Total credits >= 1?"}
    L4["[Ledger] LEAD_UNLOCK_DEBIT promo first, then paid"]
    L5["[Backend] Create LeadUnlock and credit breakdown"]
    L6["[Backend] Accept assignment and create Match"]
    L7["[WhatsApp] Notify customer/provider after commit"]
    L8["[WhatsApp/PWA] Block and show top-up guidance"]
  end

  subgraph Refunds["Disputes / Refunds / Adjustments"]
    R1["[Provider/Admin] Lead unlock dispute opened"]
    R2{"[Admin] Dispute approved?"}
    R3["[Ledger] LEAD_REFUND_CREDIT by original split"]
    R4["[Wallet] Restore paid/promo balance"]
    R5["[Admin] Manual ADMIN_ADJUSTMENT"]
    R6["[Placeholder] PAYMENT_REVERSAL and PROMO_EXPIRY not wired"]
  end

  subgraph Reconciliation["Reconciliation / Audit"]
    C1["[Ops] PaymentIntent vs bank/PayFast records"]
    C2["[Ops] Wallet balance vs latest ledger snapshots"]
    C3["[Ops] LeadUnlock vs LEAD_UNLOCK_DEBIT"]
    C4["[Ops] ProviderPromoAward vs PROMO_CREDIT"]
    C5["[Backend] Reconciliation utility flags wallet, payment, promo, and unlock exceptions"]
    C6["[Gap] No scheduled reconciliation job or admin exception dashboard yet"]
  end

  A --> O1
  O1 --> O2 --> O3
  O3 -- "No" --> O4 --> O5 --> B1
  O3 -- "Yes" --> O6 --> B1

  A --> T1 --> T2
  T2 -- "Manual EFT" --> T3 --> T4 --> T5 --> T9 --> T10 --> T11 --> B1
  T2 -- "PayFast" --> T6 --> T7 --> T8 --> T9

  B1 --> B3
  B1 --> B4
  B2 --> B3
  B2 --> B4

  A --> L1 --> L2 --> L3
  L3 -- "Yes" --> L4 --> L5 --> L6 --> L7 --> B1
  L3 -- "No" --> L8 --> T1

  L5 --> R1 --> R2
  R2 -- "Approved" --> R3 --> R4 --> B1
  R2 -- "Rejected" --> B2
  B4 --> R5 --> B1
  R6 --> C1

  O4 --> B2
  T9 --> B2
  T11 --> B2
  L4 --> B2
  R3 --> B2
  R5 --> B2
  B1 --> C2
  B2 --> C2
  L5 --> C3
  O2 --> C4
  C1 --> C5
  C2 --> C5
  C3 --> C5
  C4 --> C5
  C5 --> C6
