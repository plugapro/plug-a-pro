// Plug A Pro Admin CRUD — Prisma schema additions.
//
// This file shows the full shape of the models referenced by the scaffold.
// When lifting into the real repo: MERGE these additions into the existing
// schema rather than replacing it. Every addition is backward-compatible.
//
// Existing models (Customer, Provider, Booking, JobRequest, Match, Quote,
// Payment, Dispute, Application) are SHOWN below only with the fields the
// scaffold references — your real models likely have more. Keep your fields;
// just ADD the ones marked NEW.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// WS-E  Admin users & roles
// ---------------------------------------------------------------------------

enum Role {
  OPS
  FINANCE
  TRUST
  ADMIN
  OWNER
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  roles        Role[]
  isActive     Boolean   @default(true)
  invitedBy    String?
  invitedAt    DateTime  @default(now())
  lastLoginAt  DateTime?
  archivedAt   DateTime?

  // Reverse relation: who actioned what
  auditEvents  AdminAuditEvent[] @relation("AdminUserAuditActor")

  @@index([isActive])
  @@index([archivedAt])
}

// ---------------------------------------------------------------------------
// WS-B  Audit
// ---------------------------------------------------------------------------

model AdminAuditEvent {
  id          String    @id @default(cuid())
  entityType  String    // 'Customer' | 'Provider' | 'AdminUser' | ...
  entityId    String
  action      String    // 'create' | 'update' | 'deactivate' | 'delete' | 'merge' | 'custom:<name>'
  payload     Json      // { before, after, reason, custom }
  actorUserId String
  createdAt   DateTime  @default(now())

  actor       AdminUser @relation("AdminUserAuditActor", fields: [actorUserId], references: [id])

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// WS-B  Feature flags
// ---------------------------------------------------------------------------

model FeatureFlag {
  key              String   @id
  enabled          Boolean  @default(false)
  enabledForUsers  String[] // AdminUser ids
  description      String?
  updatedAt        DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// WS-C  Customer extensions
//
// The fields marked NEW must be ADDED to your existing Customer model.
// Do not rename existing fields.
// ---------------------------------------------------------------------------

enum CustomerChannel {
  WHATSAPP
  PWA
  BOTH
}

enum CustomerInternalFlag {
  VIP
  HIGH_RISK
  DO_NOT_CONTACT_AFTER_18
  PAYMENT_RISK
  FRAUD_SUSPECTED
}

model Customer {
  id                    String    @id @default(cuid())
  name                  String
  phone                 String    @unique
  email                 String?
  channel               CustomerChannel @default(WHATSAPP)
  createdAt             DateTime  @default(now())
  // ... your existing fields ...

  // NEW — WS-C
  address               String?
  isBlocked             Boolean   @default(false)
  blockedReason         String?
  blockedAt             DateTime?
  suspendedUntil        DateTime?
  suspendedReason       String?
  internalFlags         CustomerInternalFlag[]
  marketingOptIn        Boolean   @default(false)
  serviceOptIn          Boolean   @default(true)
  archivedAt            DateTime?
  archiveReason         String?
  // END NEW

  notes                 CustomerNote[]
  // bookings Booking[] — existing relation

  @@index([isBlocked])
  @@index([archivedAt])
  @@index([name])
  @@index([email])
}

model CustomerNote {
  id          String   @id @default(cuid())
  customerId  String
  authorId    String
  body        String
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author      AdminUser @relation(fields: [authorId], references: [id])

  @@index([customerId, createdAt])
}

// ---------------------------------------------------------------------------
// WS-D  Provider extensions
// ---------------------------------------------------------------------------

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum ProviderStatus {
  APPLICATION_PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model Provider {
  id                  String         @id @default(cuid())
  name                String
  phone               String         @unique
  createdAt           DateTime       @default(now())
  // ... your existing fields: skills, serviceAreas, availability, ...

  // NEW — WS-D
  status              ProviderStatus @default(APPLICATION_PENDING)
  kycStatus           KycStatus      @default(NOT_STARTED)
  payoutVerifiedAt    DateTime?
  suspendedUntil      DateTime?
  suspendedReason     String?
  strikes             Int            @default(0)
  archivedAt          DateTime?
  archiveReason       String?
  // END NEW

  certifications      ProviderCertification[]
  equipment           ProviderEquipment[]
  notes               ProviderNote[]

  @@index([status])
  @@index([kycStatus])
  @@index([archivedAt])
  @@index([name])
}

model ProviderCertification {
  id            String    @id @default(cuid())
  providerId    String
  type          String    // 'Electrical COC' | 'Plumbing Trade Test' | ...
  number        String?
  issuedAt      DateTime?
  expiresAt     DateTime?
  attachmentUrl String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  provider      Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([expiresAt])
}

model ProviderEquipment {
  id          String    @id @default(cuid())
  providerId  String
  type        String    // 'Multimeter' | 'Cordless drill' | ...
  notes       String?
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  provider    Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
}

model ProviderNote {
  id          String   @id @default(cuid())
  providerId  String
  authorId    String
  body        String
  isStrike    Boolean  @default(false)
  createdAt   DateTime @default(now())

  provider    Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  author      AdminUser @relation(fields: [authorId], references: [id])

  @@index([providerId, createdAt])
}

// ---------------------------------------------------------------------------
// Reference: existing models are NOT duplicated here.
// Leave your existing Booking, JobRequest, Match, Quote, Payment, Dispute,
// Application, Location, Category models alone. The scaffold refers to them
// but does not change them in this slice.
// ---------------------------------------------------------------------------
