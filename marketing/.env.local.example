# Copy to .env.local and fill in values before running locally.
# On Vercel: add these via the dashboard or `vercel env add`.

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=
VERCEL_OIDC_TOKEN=   # via: vercel link → vercel env pull
NEXT_PUBLIC_APP_URL=https://app.plugapro.co.za   # web app origin; drives "Book on the web" CTAs
